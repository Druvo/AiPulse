@page "/bookmarks"
@attribute [Authorize]
@rendermode InteractiveServer
@inject ReadingStateService Reading
@inject ObsidianExportService Export

<PageTitle>AiPulse · Reading List</PageTitle>

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
    <h1 class="mb-0">🔖 Reading List</h1>
    <button class="btn btn-success" @onclick="ExportNow">📝 Export to Obsidian</button>
</div>
<p class="text-muted">Articles you saved from the News Feed. They persist across restarts.</p>
@if (_exportMsg is not null)
{
    <div class="alert alert-success py-2 small">@_exportMsg</div>
}

@{
    var items = Reading.Bookmarks;
}

@if (items.Count == 0)
{
    <p>Nothing saved yet. Open the <a href="news">News Feed</a> and click the 🏷️ button on any article to save it here.</p>
}
else
{
    <p class="text-muted small">@items.Count saved</p>
    @foreach (var b in items)
    {
        <div class="card mb-2">
            <div class="card-body py-2">
                <div class="d-flex justify-content-between align-items-start gap-2">
                    <a href="@b.Link" target="_blank" rel="noopener" class="h6 mb-1 text-decoration-none">@b.Title</a>
                    <button class="btn btn-sm btn-outline-danger" @onclick="() => Remove(b.Link)">Remove</button>
                </div>
                <div class="x-small text-muted">
                    @b.SourceName
                    @if (!string.IsNullOrWhiteSpace(b.Category)) { <span>· @b.Category</span> }
                    · saved @b.SavedAt.ToLocalTime().ToString("g")
                </div>
            </div>
        </div>
    }
}

@code {
    private string? _exportMsg;

    private void Remove(string link) => Reading.RemoveBookmark(link);

    private void ExportNow()
    {
        var path = Export.ExportReadingList();
        _exportMsg = $"Exported {Reading.Bookmarks.Count} item(s) to {path}";
    }
}
