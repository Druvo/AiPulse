@page "/settings"
@attribute [Authorize]
@rendermode InteractiveServer
@inject ReadingStateService Reading
@inject ObsidianExportService Export
@inject WebhookService Webhooks
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>AiPulse · Settings</PageTitle>

<div class="page-header">
    <h1><Icon Name="settings" Size="22" /> Settings</h1>
    <p class="lead">Your personal preferences — watchlist, filters, notifications, and export. New to AiPulse? See the <a href="help">Help page</a> first.</p>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <h4 class="section-title"><Icon Name="star" /> Keyword watchlist</h4>
        <p class="text-muted">Topics you care about. Matching feed items get a star badge and trigger a desktop notification.</p>

        <div class="input-group mb-3">
            <input class="form-control" placeholder="e.g. MCP, Blazor, RAG" @bind="_newKeyword" @bind:event="oninput"
                   @onkeydown="@(e => { if (e.Key == "Enter") AddKeyword(); })" />
            <button class="btn btn-primary" @onclick="AddKeyword">Add</button>
        </div>

        @if (Reading.Watchlist.Count == 0)
        {
            <p class="text-muted">No keywords yet.</p>
        }
        else
        {
            <div class="d-flex flex-wrap gap-2">
                @foreach (var k in Reading.Watchlist)
                {
                    <span class="badge bg-warning p-2">
                        @k
                        <button class="btn-close btn-close-sm ms-1" style="font-size:.6rem;"
                                @onclick="() => Remove(k)" aria-label="remove"></button>
                    </span>
                }
            </div>
        }

        <hr class="my-4" />

        <h4 class="section-title"><Icon Name="star" /> Exclude filters</h4>
        <p class="text-muted">The opposite of the watchlist — matching items are hidden from the News feed entirely. Use plain text, or check "regex" for a regular expression.</p>

        <div class="input-group mb-2">
            <input class="form-control" placeholder="e.g. crypto, or a regex like ^Sponsored:" @bind="_newFilterPattern" @bind:event="oninput"
                   @onkeydown="@(e => { if (e.Key == "Enter") AddExcludeFilter(); })" />
            <div class="input-group-text">
                <input class="form-check-input mt-0 me-1" type="checkbox" @bind="_newFilterIsRegex" id="newFilterRegex" />
                <label class="form-check-label" for="newFilterRegex">regex</label>
            </div>
            <button class="btn btn-primary" @onclick="AddExcludeFilter">Add</button>
        </div>

        @if (Reading.ExcludeFilters.Count == 0)
        {
            <p class="text-muted">No exclude filters yet.</p>
        }
        else
        {
            <div class="d-flex flex-column gap-1">
                @foreach (var f in Reading.ExcludeFilters)
                {
                    <div class="d-flex align-items-center gap-2">
                        <code class="small">@f.Pattern</code>
                        @if (f.IsRegex)
                        {
                            <span class="badge bg-secondary">regex</span>
                        }
                        <button class="btn btn-sm btn-link p-0 text-danger" @onclick="() => RemoveExcludeFilter(f.Id)">remove</button>
                    </div>
                }
            </div>
        }

        <hr class="my-4" />

        <h4 class="section-title"><Icon Name="sparkle" /> Appearance</h4>
        <p class="text-muted">An accent color on top of the light/dark toggle (top-left), plus optional custom CSS for full control. Remembered on this browser.</p>

        <div class="d-flex gap-2 mb-3">
            <button class="accent-swatch" style="background:#0891b2" title="Default (teal)" @onclick='() => SetAccent("")'></button>
            <button class="accent-swatch" style="background:#7c3aed" title="Violet" @onclick='() => SetAccent("violet")'></button>
            <button class="accent-swatch" style="background:#e11d48" title="Rose" @onclick='() => SetAccent("rose")'></button>
            <button class="accent-swatch" style="background:#d97706" title="Amber" @onclick='() => SetAccent("amber")'></button>
            <button class="accent-swatch" style="background:#059669" title="Emerald" @onclick='() => SetAccent("emerald")'></button>
        </div>

        <details>
            <summary class="small text-muted mb-2" style="cursor:pointer">Advanced: custom CSS</summary>
            <textarea class="form-control form-control-sm font-monospace mt-2" rows="6" placeholder="e.g. .stat-num { font-size: 2.5rem; }" @bind="_customCss"></textarea>
            <button class="btn btn-sm btn-outline-primary mt-2" @onclick="SaveCustomCss">Apply</button>
        </details>
    </div>

    <div class="col-lg-6">
        <h4 class="section-title"><Icon Name="bell" /> Desktop notifications</h4>
        <p class="text-muted">Get notified about new tool/model releases and watchlist hits while a tab is open.</p>
        <p>Browser permission: <strong>@_permission</strong></p>
        @if (_permission == "denied")
        {
            <div class="alert alert-warning py-2 small">
                Notifications are <strong>blocked</strong> for this site. Once blocked, no website can re-prompt you —
                you have to allow it manually: click the padlock/site-info icon next to the address bar →
                <strong>Notifications</strong> → <strong>Allow</strong>, then reload this page.
            </div>
        }
        <button class="btn btn-outline-primary me-2" @onclick="RequestPermission">Enable notifications</button>
        <button class="btn btn-outline-secondary" @onclick="TestNotification">Send test</button>
        @if (_testResult is not null)
        {
            <div class="alert @(_testResult == "shown" ? "alert-success" : "alert-warning") py-2 mt-2 small">@TestResultMessage()</div>
        }
        <p class="text-muted small mt-2">
            Background alerts (releases/watchlist) only fire for items published <em>after</em> the app's first poll on startup,
            and re-check every <code>Notifications:PollMinutes</code> (default 15 min, in <code>appsettings.json</code>) —
            so nothing shows in the first few minutes after a restart even when everything's working correctly.
        </p>

        <hr class="my-4" />

        <h4 class="section-title"><Icon Name="webhook" /> Outbound webhook</h4>
        <p class="text-muted">
            Desktop notifications only fire while a tab is open. A webhook reaches you anywhere — paste a
            <a href="https://api.slack.com/messaging/webhooks" target="_blank" rel="noopener">Slack</a> or
            <a href="https://support.discord.com/hc/en-us/articles/228383668" target="_blank" rel="noopener">Discord</a>
            incoming-webhook URL and it's auto-detected; any other URL gets a generic JSON POST.
        </p>
        <div class="input-group mb-2">
            <input class="form-control" placeholder="https://hooks.slack.com/services/…" @bind="_webhookUrl" />
            <button class="btn btn-primary" @onclick="SaveWebhook">Save</button>
        </div>
        <button class="btn btn-outline-secondary" @onclick="TestWebhook" disabled="@string.IsNullOrWhiteSpace(_webhookUrl)">Send test</button>
        @if (_webhookTestResult is not null)
        {
            <div class="alert @(_webhookTestResult == "ok" ? "alert-success" : "alert-warning") py-2 mt-2 small">
                @(_webhookTestResult == "ok" ? "Test message sent — check your channel." : $"Failed: {_webhookTestResult}")
            </div>
        }

        <hr class="my-4" />

        <h4 class="section-title"><Icon Name="rss" /> Mobile apps (Fever API)</h4>
        <p class="text-muted">
            Read AiPulse from an RSS app that supports the <strong>Fever API</strong> (Reeder, ReadKit, Fiery Feeds, and others).
            Set a separate password here — it's not your login password, just for this.
        </p>
        <div class="input-group mb-2">
            <input type="password" class="form-control" placeholder="Fever API password" @bind="_feverPassword" />
            <button class="btn btn-primary" @onclick="SaveFeverPassword">Save</button>
        </div>
        @if (_feverSaved)
        {
            <div class="alert alert-success py-2 small mb-2">
                Saved. In your RSS app, use server <code>@_feverEndpointUrl</code>, username <code>@_username</code>, and the password you just set.
            </div>
        }
        @if (Reading.FeverApiKey is not null)
        {
            <p class="text-muted small mb-0">Fever API access is currently <strong class="text-success">enabled</strong> for this account.</p>
        }

        <hr class="my-4" />

        <h4 class="section-title"><Icon Name="grid" /> Dashboard widgets</h4>
        <p class="text-muted">
            Embed your own content on the Dashboard — a status page, a personal RSS reader, a Grafana panel, anything.
            <strong>Iframe</strong> takes a URL. <strong>HTML</strong> renders raw markup directly, unsanitized — only use it
            with content you trust, since it runs as your own logged-in session (the same trust model as the custom CSS above).
        </p>
        <div class="row g-2 mb-2">
            <div class="col-md-3">
                <input class="form-control" placeholder="Title" @bind="_newWidgetTitle" />
            </div>
            <div class="col-md-2">
                <select class="form-select" @bind="_newWidgetType">
                    <option value="Iframe">Iframe</option>
                    <option value="Html">HTML</option>
                </select>
            </div>
            <div class="col-md-5">
                <input class="form-control" placeholder="@(_newWidgetType == "Iframe" ? "https://…" : "<div>…</div>")" @bind="_newWidgetContent" />
            </div>
            <div class="col-md-2">
                <button class="btn btn-primary w-100" @onclick="AddWidget">Add</button>
            </div>
        </div>

        @if (Reading.DashboardWidgets.Count == 0)
        {
            <p class="text-muted">No widgets yet.</p>
        }
        else
        {
            <div class="d-flex flex-column gap-1">
                @foreach (var w in Reading.DashboardWidgets)
                {
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-secondary">@w.Type</span>
                        <span class="small fw-bold">@w.Title</span>
                        <code class="small text-truncate" style="max-width:260px">@w.Content</code>
                        <button class="btn btn-sm btn-link p-0 text-danger ms-auto" @onclick="() => RemoveWidget(w.Id)">remove</button>
                    </div>
                }
            </div>
        }

        <hr class="my-4" />

        <h4 class="section-title"><Icon Name="download" /> Export to Obsidian</h4>
        <p class="text-muted">Folder to write <code>AiPulse Reading List.md</code> into. Point this at your Obsidian vault to export there instead.</p>
        <div class="input-group mb-2">
            <input class="form-control" placeholder="@Export.TargetDir" @bind="_exportPath" />
            <button class="btn btn-primary" @onclick="SavePath">Save</button>
        </div>
        <button class="btn btn-success" @onclick="ExportNow">Export reading list now</button>
        @if (_exportMsg is not null)
        {
            <div class="alert alert-success mt-2 py-2 small">@_exportMsg</div>
        }

        <AuthorizeView Roles="Admin">
            <Authorized>
                <hr class="my-4" />

                <h4 class="section-title"><Icon Name="database" /> Backup &amp; restore</h4>
                <p class="text-muted">
                    Sources, all users' bookmarks/watchlists, Playground chat history, and feed history all live in <code>App_Data/</code>.
                    Back it up before upgrading or migrating to a new machine. Admin-only since this covers every user's data.
                </p>
                <a href="/backup/download" class="btn btn-outline-primary mb-3"><Icon Name="download" Size="14" /> Download backup (.zip)</a>

                <form method="post" action="/backup/restore" enctype="multipart/form-data"
                      onsubmit="return confirm('This overwrites ALL current sources, bookmarks, chat history and feed history with the contents of this backup. Continue?');">
                    <div class="input-group">
                        <input type="file" name="file" accept=".zip" class="form-control" required />
                        <button type="submit" class="btn btn-warning">Restore from backup</button>
                    </div>
                    <p class="text-muted small mt-1">Restart AiPulse after restoring so every page picks up the restored data.</p>
                </form>
                @if (RestoredParam == "true")
                {
                    <div class="alert alert-success mt-2 py-2 small">Backup restored. Please restart AiPulse now.</div>
                }
            </Authorized>
        </AuthorizeView>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "restored")]
    public string? RestoredParam { get; set; }

    private string _newKeyword = "";
    private string _newFilterPattern = "";
    private bool _newFilterIsRegex;
    private string? _exportPath;
    private string _permission = "unknown";
    private string? _exportMsg;
    private string? _testResult;
    private string _customCss = "";
    private string _webhookUrl = "";
    private string? _webhookTestResult;
    private string _feverPassword = "";
    private bool _feverSaved;
    private string _username = "";
    private string _feverEndpointUrl = "";
    private string _newWidgetTitle = "";
    private string _newWidgetType = "Iframe";
    private string _newWidgetContent = "";

    protected override void OnInitialized()
    {
        _exportPath = Reading.ObsidianExportPath ?? Export.TargetDir;
        _webhookUrl = Reading.WebhookUrl ?? "";
        _feverEndpointUrl = new Uri(new Uri(Nav.Uri), "/fever/").ToString();
    }

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        _username = state.User.Identity?.Name ?? "";
    }

    private void SaveFeverPassword()
    {
        if (string.IsNullOrWhiteSpace(_feverPassword)) return;
        Reading.SetFeverApiPassword(_username, _feverPassword);
        _feverPassword = "";
        _feverSaved = true;
    }

    private void SaveWebhook() => Reading.SetWebhookUrl(_webhookUrl);

    private async Task TestWebhook()
    {
        var (success, error) = await Webhooks.SendTestAsync(_webhookUrl);
        _webhookTestResult = success ? "ok" : (error ?? "unknown error");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try { _permission = await JS.InvokeAsync<string>("aipulseNotify.permission"); StateHasChanged(); } catch { }
        try
        {
            _customCss = await JS.InvokeAsync<string>("eval", "localStorage.getItem('aipulse-custom-css') || ''");
            StateHasChanged();
        }
        catch { }
    }

    private async Task SetAccent(string name)
    {
        try { await JS.InvokeVoidAsync("setAccent", name); } catch { }
    }

    private async Task SaveCustomCss()
    {
        try { await JS.InvokeVoidAsync("setCustomCss", _customCss); } catch { }
    }

    private void AddKeyword()
    {
        Reading.AddKeyword(_newKeyword);
        _newKeyword = "";
    }

    private void Remove(string k) => Reading.RemoveKeyword(k);

    private void AddExcludeFilter()
    {
        Reading.AddExcludeFilter(_newFilterPattern, _newFilterIsRegex);
        _newFilterPattern = "";
        _newFilterIsRegex = false;
    }

    private void RemoveExcludeFilter(Guid id) => Reading.RemoveExcludeFilter(id);

    private void AddWidget()
    {
        if (string.IsNullOrWhiteSpace(_newWidgetTitle) || string.IsNullOrWhiteSpace(_newWidgetContent)) return;
        Reading.AddDashboardWidget(_newWidgetTitle, _newWidgetType, _newWidgetContent);
        _newWidgetTitle = "";
        _newWidgetContent = "";
    }

    private void RemoveWidget(Guid id) => Reading.RemoveDashboardWidget(id);

    private async Task RequestPermission()
    {
        try { _permission = await JS.InvokeAsync<string>("aipulseNotify.requestPermission"); } catch { }
    }

    private async Task TestNotification()
    {
        try { _testResult = await JS.InvokeAsync<string>("aipulseNotify.show", "AiPulse", "Notifications are working.", ""); }
        catch (Exception ex) { _testResult = "error: " + ex.Message; }
    }

    private string TestResultMessage() => _testResult switch
    {
        "shown" => "Test notification sent — check your OS notification area if you didn't see it pop up.",
        "denied" => "Blocked by the browser. See the message above for how to unblock it.",
        "unsupported" => "This browser doesn't support desktop notifications.",
        _ => $"Couldn't show a notification ({_testResult})."
    };

    private void SavePath()
    {
        Reading.SetObsidianExportPath(_exportPath);
        _exportMsg = "Export folder saved.";
    }

    private void ExportNow()
    {
        var path = Export.ExportReadingList();
        _exportMsg = $"Exported {Reading.Bookmarks.Count} item(s) to {path}";
    }
}
