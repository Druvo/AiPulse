@page "/forgot-password"
@layout AiPulse.Components.Layout.EmptyLayout
@rendermode InteractiveServer
@inject UserService Users
@inject NavigationManager Nav

<PageTitle>AiPulse · Forgot password</PageTitle>

<div class="login-shell-inner">
<div class="login-card">
    <div class="login-logo-wrap">
        <img src="/img/logo-v1.png" alt="AiPulse" class="app-logo login-logo" />
    </div>
    <h1 class="login-brand-mark">AiPulse</h1>
    <p class="text-muted text-center mb-4">Reset your password</p>

    @if (_submitted)
    {
        <div class="alert alert-success">
            If that email matches an account, a reset link has been sent. (No SMTP configured? An admin can generate the link for you from Users.)
        </div>
        <a class="btn btn-primary w-100" href="/login">Back to sign in</a>
    }
    else
    {
        <EditForm Model="_form" OnValidSubmit="Submit">
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" class="form-control" @bind="_form.Email" autocomplete="email" />
            </div>
            <button type="submit" class="btn btn-primary w-100">Send reset link</button>
        </EditForm>

        <p class="text-center text-muted small mt-3 mb-0">
            <a href="/login">Back to sign in</a>
        </p>
    }
</div>
<p class="login-signature">Made with <span class="text-danger">♥</span> by <a href="https://github.com/Druvo" target="_blank" rel="noopener">Druvo</a></p>
</div>

@code {
    private readonly ForgotForm _form = new();
    private bool _submitted;

    private async Task Submit()
    {
        var baseUrl = Nav.BaseUri.TrimEnd('/');
        await Users.RequestPasswordResetAsync(_form.Email, token => $"{baseUrl}/reset-password?token={token}");
        _submitted = true;
    }

    private sealed class ForgotForm
    {
        public string Email { get; set; } = "";
    }
}
