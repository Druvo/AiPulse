@page "/learn"
@attribute [Authorize]
@rendermode InteractiveServer
@inject KnowledgeBaseService Kb
@inject ReadingStateService Reading
@inject FeedHistoryService History
@inject NavigationManager Nav
@inject HuggingFaceService HuggingFace
@inject GitHubTrendingService GitHub
@inject ObsidianExportService Export
@inject ToastService Toasts

<PageTitle>AiPulse · Learning Hub</PageTitle>

<div class="page-header">
    <h1><Icon Name="graduation-cap" Size="22" /> Learning Hub</h1>
    <p class="lead">A roadmap from fundamentals to agents. Work top to bottom, or jump to what you need. Each module says <em>why</em> it matters and gives concrete steps.</p>
</div>

@{
    var freshTutorials = History.Items
        .Where(i => i.ContentType == "Tutorial")
        .OrderByDescending(i => i.Published)
        .Take(8)
        .ToList();
}
@if (freshTutorials.Count > 0)
{
    <div class="card mb-4">
        <div class="card-body">
            <h6 class="section-title mb-2"><Icon Name="sparkle" Size="16" /> Fresh tutorials</h6>
            <p class="text-muted small mb-2">Recently published, pulled live from your News sources — the roadmap below covers the fundamentals; this keeps you current on what's new.</p>
            <div class="row g-2">
                @foreach (var t in freshTutorials)
                {
                    <div class="col-md-6">
                        <a href="@t.Link" target="_blank" rel="noopener" class="d-block small text-decoration-none border-bottom py-1">
                            @t.Title
                            <span class="text-muted"> · @t.SourceName</span>
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="card mb-4">
    <div class="card-body">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
            <h6 class="section-title mb-0"><Icon Name="sparkle" Size="16" /> Trending in the ecosystem right now</h6>
            <div class="d-flex align-items-center gap-2">
                <button class="btn btn-sm btn-outline-secondary py-0 px-2" disabled="@_trendingLoading" @onclick="() => LoadTrendingAsync(true)">
                    <Icon Name="refresh" Size="13" /> Refresh
                </button>
                @if (_trendingLastUpdated is { } lu)
                {
                    <span class="x-small text-muted">Updated @lu.ToLocalTime().ToString("t")</span>
                }
            </div>
        </div>
        <p class="text-muted small mb-2">The models and projects getting the most attention this week — via Hugging Face and GitHub. Good candidates for what to learn next.</p>

        @if (_trendingLoading && _trendingModels.Count == 0 && _trendingRepos.Count == 0)
        {
            <div class="row g-2">
                <div class="col-md-6">
                    <div class="skeleton-line w-40"></div>
                    <div class="skeleton-line w-80"></div>
                    <div class="skeleton-line w-60"></div>
                </div>
                <div class="col-md-6">
                    <div class="skeleton-line w-40"></div>
                    <div class="skeleton-line w-80"></div>
                    <div class="skeleton-line w-60"></div>
                </div>
            </div>
        }
        else if (_trendingModels.Count > 0 || _trendingRepos.Count > 0)
        {
            <div class="row g-2">
                <div class="col-md-6">
                    <p class="x-small text-muted text-uppercase mb-1">Trending models</p>
                    @foreach (var m in _trendingModels.Take(5))
                    {
                        <a href="@m.Url" target="_blank" rel="noopener" class="d-block small text-decoration-none border-bottom py-1">@m.Id</a>
                    }
                </div>
                <div class="col-md-6">
                    <p class="x-small text-muted text-uppercase mb-1">Trending repos</p>
                    @foreach (var r in _trendingRepos.Take(5))
                    {
                        <a href="@r.Url" target="_blank" rel="noopener" class="d-block small text-decoration-none border-bottom py-1">@r.FullName</a>
                    }
                </div>
            </div>
            <a href="explore" class="small">Explore models, benchmarks &amp; datasets →</a>
        }
        else
        {
            <EmptyState Icon="trending-up" Title="No trending data yet" Body="Couldn't reach Hugging Face or GitHub - try Refresh above." />
        }
    </div>
</div>

@{
    var trendingTags = TrendingTags();
    var uncoveredTags = UncoveredTrendingTags(trendingTags);
}
@if (uncoveredTags.Count > 0)
{
    <div class="card mb-4">
        <div class="card-body">
            <h6 class="section-title mb-2"><Icon Name="trending-up" Size="16" /> Emerging topics not yet in your roadmap</h6>
            <p class="text-muted small mb-2">
                Tags showing up a lot in your News Feed over the last 14 days that no module below covers yet -
                this is the "what's next" radar: today's chatter, tomorrow's module. No AI involved - just
                counting how often each tag appears across your own sources. Queued below for an admin to turn
                into a real module.
            </p>
            <div class="d-flex flex-wrap gap-1">
                @foreach (var tag in uncoveredTags)
                {
                    <a class="tag-chip small" href="@($"news?tag={Uri.EscapeDataString(tag)}")">@tag</a>
                }
            </div>
        </div>
    </div>
}

<AuthorizeView Roles="Admin" Context="adminPanel">
    <Authorized>
        @if (_pendingCandidates.Count > 0)
        {
            <div class="card mb-4">
                <div class="card-body">
                    <strong class="d-block mb-2"><Icon Name="search" Size="16" /> Candidate modules awaiting review (@_pendingCandidates.Count)</strong>
                    <div class="d-flex flex-column gap-2">
                        @foreach (var c in _pendingCandidates)
                        {
                            @if (_approvingCandidateId == c.Id)
                            {
                                <div class="border rounded p-2">
                                    <EditForm Model="_form" OnValidSubmit="ConfirmApprove">
                                        <div class="row g-2 mb-2">
                                            <div class="col-md-6"><InputText class="form-control form-control-sm" @bind-Value="_form.Title" placeholder="Title" /></div>
                                            <div class="col-md-6">
                                                <InputSelect class="form-select form-select-sm" @bind-Value="_form.Level">
                                                    <option value="Beginner">Beginner</option>
                                                    <option value="Intermediate">Intermediate</option>
                                                    <option value="Advanced">Advanced</option>
                                                </InputSelect>
                                            </div>
                                        </div>
                                        <InputText class="form-control form-control-sm mb-2" @bind-Value="_form.Why" placeholder="Why this matters (required)" />
                                        <InputTextArea class="form-control form-control-sm mb-2" rows="4" @bind-Value="_form.Steps" placeholder="Steps (one per line)" />
                                        <InputText class="form-control form-control-sm mb-2" @bind-Value="_form.RelatedTerms" placeholder="Related terms (comma-separated)" />
                                        @if (_error is not null)
                                        {
                                            <div class="alert alert-danger py-1 px-2 small mb-2">@_error</div>
                                        }
                                        <button type="submit" class="btn btn-sm btn-success">Add module</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => _approvingCandidateId = null">Cancel</button>
                                    </EditForm>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-between gap-2 border rounded p-2">
                                    <div class="small">
                                        <strong>@c.Name</strong>
                                        <span class="text-muted"> — @c.RawNote</span>
                                    </div>
                                    <div class="text-nowrap">
                                        <button class="btn btn-sm btn-outline-success" @onclick="() => StartApprove(c)">Review</button>
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => Dismiss(c.Id)">Dismiss</button>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        }
    </Authorized>
</AuthorizeView>

@{
    var strengths = TopicStrengths();
}
@if (strengths.Count > 0)
{
    <div class="card mb-4">
        <div class="card-body">
            <h6 class="section-title mb-2"><Icon Name="activity" Size="16" /> Topic strength</h6>
            <p class="text-muted small mb-2">
                Where completed modules and what you've actually been reading overlap - module completion plus
                RelatedTerms-tagged articles read in the last 30 days. Not just "did you open the module," but
                whether it's showing up in what you read too.
            </p>
            <div class="d-flex flex-column gap-1">
                @foreach (var s in strengths)
                {
                    <div class="d-flex align-items-center justify-content-between gap-2 small border-bottom py-1">
                        <span>@s.Module.Title @if (s.Complete) { <span class="text-success">✓</span> }</span>
                        <span class="text-muted x-small">@(s.ArticlesRead > 0 ? $"{s.ArticlesRead} article(s) read recently" : "completed, not much recent reading")</span>
                    </div>
                }
            </div>
        </div>
    </div>
}

@{
    var refreshers = Refreshers();
}
@if (refreshers.Count > 0)
{
    <div class="card mb-4 refresher-shelf">
        <div class="card-body">
            <h6 class="section-title mb-2"><Icon Name="activity" Size="16" /> Worth a refresher</h6>
            <p class="text-muted small mb-2">Completed six or more weeks ago - concepts fade, and nothing else in the app ever asks you to revisit them. No pressure, just a nudge.</p>
            <div class="row g-2">
                @foreach (var m in refreshers)
                {
                    <div class="col-md-6">
                        <div class="card h-100">
                            <div class="card-body py-2">
                                <div class="small fw-bold">@m.Title</div>
                                <div class="x-small text-muted">Completed @Reading.ModuleCompletedAt[m.Title].ToString("MMM d")</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@{
    var courses = Kb.Courses
        .Where(c => _level == "All" || c.Level == _level)
        .OrderByDescending(c => c.Topics.Any(t => trendingTags.Contains(t)))
        .ThenBy(c => c.Name)
        .ToList();
}
@if (courses.Count > 0)
{
    <div class="card mb-4">
        <div class="card-body">
            <h6 class="section-title mb-2"><Icon Name="graduation-cap" Size="16" /> Free courses &amp; certifications</h6>
            <p class="text-muted small mb-2">Curated, genuinely free courses — each one notes honestly whether the certificate itself is free or just the course content. Filtered by the level buttons below.</p>
            <div class="row g-2">
                @foreach (var c in courses)
                {
                    var trending = c.Topics.Any(t => trendingTags.Contains(t));
                    <div class="col-md-6">
                        <div class="card h-100">
                            <div class="card-body py-2">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <a href="@c.Url" target="_blank" rel="noopener" class="fw-bold small text-decoration-none">@c.Name ↗</a>
                                    @if (trending)
                                    {
                                        <span class="badge bg-warning text-dark">🔥 Trending</span>
                                    }
                                </div>
                                <div class="x-small text-muted mb-1">@c.Provider · <span class="badge level-@c.Level.ToLower()">@c.Level</span></div>
                                <p class="small mb-1">@c.OneLiner</p>
                                <div class="x-small @(c.HasFreeCertificate ? "text-success" : "text-muted")">
                                    @(c.HasFreeCertificate ? "✓ Free certificate" : "ⓘ") @c.CertificateNote
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-1">
    <p class="text-muted small mb-0">@Reading.CompletedModuleCount of @Kb.Learning.Count modules complete</p>
    <div class="d-flex align-items-center gap-3">
        @if (LearningStreak() > 0)
        {
            <span class="small">@LearningStreak() 🔥 <span class="text-muted">day learning streak</span></span>
        }
        @if (!string.IsNullOrEmpty(LearningTimeLabel()))
        {
            <span class="small text-muted">@LearningTimeLabel()</span>
        }
        <button class="btn btn-sm btn-link p-0" @onclick="ExportNotes">Export learning notes</button>
    </div>
</div>
<div class="progress mb-3" style="height: 6px;">
    <div class="progress-bar" style="width: @(ProgressPct())%"></div>
</div>

<div class="btn-group mb-4 flex-wrap" role="group">
    @foreach (var lvl in _levels)
    {
        <button class="btn btn-sm @(_level == lvl ? "btn-dark" : "btn-outline-dark")"
                @onclick="() => SetLevel(lvl)">@lvl</button>
    }
</div>

@{
    var modules = Kb.Learning.Where(m => _level == "All" || m.Level == _level).ToList();
    var i = 0;
}

@foreach (var m in modules)
{
    i++;
    var complete = Reading.IsModuleComplete(m.Title);
    var doneSteps = Reading.CompletedStepCount(m.Title, m.Steps.Length);
    var pct = m.Steps.Length == 0 ? 0 : 100.0 * doneSteps / m.Steps.Length;
    <div class="card mb-3 learn-card @(complete ? "module-complete" : "")">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-2">
                <h4 class="card-title mb-1"><span class="text-muted">@i.</span> @m.Title @if (complete) { <span class="text-success">✓</span> }</h4>
                <div class="d-flex align-items-center gap-2">
                    <span class="badge level-@m.Level.ToLower()">@m.Level</span>
                    @if (!complete)
                    {
                        <button class="btn btn-sm btn-outline-success" @onclick="() => MarkAllComplete(m)">Mark all complete</button>
                    }
                </div>
            </div>
            <p class="text-muted mb-2"><strong>Why:</strong> @m.Why</p>
            <div class="progress module-progress-mini mb-2">
                <div class="progress-bar" style="width: @(pct.ToString("0"))%"></div>
            </div>
            <div class="mb-2">
                @for (var stepIdx = 0; stepIdx < m.Steps.Length; stepIdx++)
                {
                    var idx = stepIdx;
                    var step = m.Steps[idx];
                    var done = Reading.IsStepComplete(m.Title, idx);
                    <div class="learn-step @(done ? "step-done" : "") mb-1">
                        <input type="checkbox" id="@($"{m.Title}-step-{idx}")" checked="@done" @onchange="() => ToggleStep(m, idx)" />
                        <label for="@($"{m.Title}-step-{idx}")">
                            @step.Text
                            @if (!string.IsNullOrWhiteSpace(step.Url))
                            {
                                <a href="@step.Url" target="_blank" rel="noopener" class="ms-1 small" @onclick:stopPropagation="true">↗ open</a>
                            }
                        </label>
                    </div>
                }
            </div>
            @if (m.RelatedTerms.Length > 0)
            {
                <div class="small mb-2">
                    <span class="text-muted">Key terms:</span>
                    @foreach (var t in m.RelatedTerms)
                    {
                        <a class="badge bg-info text-decoration-none me-1" href="glossary">@t</a>
                    }
                </div>
            }
            @if (complete)
            {
                var check = Reading.GetSelfCheck(m.Title);
                <div class="border-top pt-2 mt-2 small">
                    <span class="text-muted">Could you explain this to someone else right now?</span>
                    <button class="btn btn-sm @(check == true ? "btn-success" : "btn-outline-success") py-0 px-2 ms-2" @onclick="() => Reading.SetSelfCheck(m.Title, true)">Yes</button>
                    <button class="btn btn-sm @(check == false ? "btn-warning" : "btn-outline-warning") py-0 px-2 ms-1" @onclick="() => Reading.SetSelfCheck(m.Title, false)">Not yet</button>
                </div>
            }
            <div class="mt-2">
                <label class="x-small text-muted d-block mb-1" for="@($"{m.Title}-notes")">Your notes</label>
                <textarea id="@($"{m.Title}-notes")" class="form-control form-control-sm" rows="2" placeholder="Your own takeaway, once you've worked through this..."
                          value="@Reading.GetModuleNote(m.Title)" @onchange="e => Reading.SetModuleNote(m.Title, (string)e.Value!)"></textarea>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "level")]
    public string? LevelParam { get; set; }

    private string _level = "All";
    private readonly string[] _levels = { "All", "Beginner", "Intermediate", "Advanced" };
    private List<TrendingModel> _trendingModels = new();
    private List<TrendingRepo> _trendingRepos = new();
    private bool _trendingLoading = true;
    private DateTimeOffset? _trendingLastUpdated;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrWhiteSpace(LevelParam) && _levels.Contains(LevelParam))
            _level = LevelParam;

        // One-time, self-healing backfill: modules completed under the old whole-module toggle (before
        // per-step tracking existed) are in CompletedModules but have zero CompletedSteps recorded. Without
        // this, checking a single step on one of those modules would make RecomputeModuleCompletion see
        // "not all steps done" and silently un-complete a module the user had already finished.
        foreach (var m in Kb.Learning)
        {
            if (Reading.IsModuleComplete(m.Title) && m.Steps.Length > 0 && Reading.CompletedStepCount(m.Title, m.Steps.Length) == 0)
                Reading.MarkAllStepsComplete(m.Title, m.Steps.Length);
        }

        // Fire-and-forget: the learning roadmap itself is static data and should render instantly - the
        // trending models/repos panel just fills in once these resolve instead of holding up the page.
        _ = LoadTrendingAsync(force: false);
        _ = QueueUncoveredTagCandidatesAsync();
    }

    private List<ContentCandidate> _pendingCandidates = new();
    private int? _approvingCandidateId;
    private string? _error;
    private LearningForm _form = new();

    /// <summary>Turns the existing UncoveredTrendingTags tag-frequency signal into actual admin-reviewable module candidates instead of just a read-only chip list - this is what makes the Learning Hub "grow on its own."</summary>
    private async Task QueueUncoveredTagCandidatesAsync()
    {
        var existingNames = Kb.Learning.Select(m => m.Title).ToList();
        foreach (var tag in UncoveredTrendingTags(TrendingTags()))
            await Kb.AddContentCandidateIfNewAsync("Learning", tag, "Intermediate", $"Trending tag not yet covered by a module", existingNames);
        await RefreshCandidatesAsync();
    }

    private async Task RefreshCandidatesAsync() => _pendingCandidates = await Kb.GetPendingContentCandidatesAsync("Learning");

    private void StartApprove(ContentCandidate c)
    {
        _approvingCandidateId = c.Id;
        _error = null;
        _form = new LearningForm { Title = c.Name, Level = c.Category ?? "Intermediate", RelatedTerms = c.Name };
    }

    private async Task ConfirmApprove()
    {
        if (_approvingCandidateId is null) return;
        if (string.IsNullOrWhiteSpace(_form.Title) || string.IsNullOrWhiteSpace(_form.Why))
        {
            _error = "Title and 'why this matters' are required.";
            return;
        }
        var steps = _form.Steps
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(s => new LearningStep { Text = s })
            .ToArray();
        await Kb.ApproveLearningCandidateAsync(_approvingCandidateId.Value, new LearningModule
        {
            Title = _form.Title.Trim(),
            Level = _form.Level,
            Why = _form.Why.Trim(),
            Steps = steps,
            RelatedTerms = _form.RelatedTerms.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        });
        _approvingCandidateId = null;
        await RefreshCandidatesAsync();
    }

    private async Task Dismiss(int id)
    {
        await Kb.DismissContentCandidateAsync(id);
        await RefreshCandidatesAsync();
    }

    private sealed class LearningForm
    {
        public string Title { get; set; } = "";
        public string Level { get; set; } = "Intermediate";
        public string Why { get; set; } = "";
        public string Steps { get; set; } = "";
        public string RelatedTerms { get; set; } = "";
    }

    private async Task LoadTrendingAsync(bool force)
    {
        _trendingLoading = true;
        StateHasChanged();
        var (models, _) = await HuggingFace.GetTrendingAsync(force);
        _trendingModels = models;
        _trendingRepos = await GitHub.GetTrendingReposAsync(force: force);
        _trendingLastUpdated = HuggingFace.LastUpdated ?? GitHub.GetRepoLastUpdated("daily");
        _trendingLoading = false;
        StateHasChanged();
    }

    private void SetLevel(string level)
    {
        _level = level;
        Nav.NavigateTo(level == "All" ? "learn" : $"learn?level={level}", replace: true);
    }

    private double ProgressPct() =>
        Kb.Learning.Count == 0 ? 0 : 100.0 * Reading.CompletedModuleCount / Kb.Learning.Count;

    private void ToggleStep(LearningModule m, int stepIndex) => Reading.ToggleStep(m.Title, stepIndex, m.Steps.Length);
    private void MarkAllComplete(LearningModule m) => Reading.MarkAllStepsComplete(m.Title, m.Steps.Length);

    /// <summary>Consecutive days up to and including today with at least one step completed - separate from Reading Stats' article-read streak, so a day spent deep in one module without opening a news item still counts as "showed up today."</summary>
    private int LearningStreak()
    {
        var days = Reading.LearningHistory.Select(e => DateOnly.FromDateTime(e.At.LocalDateTime.Date)).ToHashSet();
        var streak = 0;
        var d = DateOnly.FromDateTime(DateTime.Now);
        while (days.Contains(d)) { streak++; d = d.AddDays(-1); }
        return streak;
    }

    private string LearningTimeLabel()
    {
        var minutes = Reading.LearningHistory.Sum(e => e.Minutes);
        if (minutes == 0) return "";
        return minutes >= 60 ? $"~{minutes / 60.0:0.#} hr in the Learning Hub" : $"~{minutes} min in the Learning Hub";
    }

    /// <summary>Modules completed 6+ weeks ago - the spaced-repetition nudge. Only modules with a recorded completion date qualify (a module completed under the pre-upgrade whole-module toggle gets one retroactively via the OnInitialized backfill above).</summary>
    private List<LearningModule> Refreshers()
    {
        var cutoff = DateTimeOffset.Now.AddDays(-42);
        var completedAt = Reading.ModuleCompletedAt;
        return Kb.Learning
            .Where(m => completedAt.TryGetValue(m.Title, out var at) && at <= cutoff)
            .OrderBy(m => completedAt[m.Title])
            .Take(4)
            .ToList();
    }

    private sealed record TopicStrength(LearningModule Module, bool Complete, int ArticlesRead);

    /// <summary>Combines module completion with how many of that module's RelatedTerms tags showed up in articles you've actually read in the last 30 days - "completed the module" and "still reading about it" are two different signals that happened to live in separate silos.</summary>
    private List<TopicStrength> TopicStrengths()
    {
        var readLinks = Reading.ReadHistory.Select(e => e.Link).ToHashSet();
        var cutoff = DateTimeOffset.UtcNow.AddDays(-30);
        var readTagCounts = History.Items
            .Where(i => i.Published >= cutoff && readLinks.Contains(i.Link))
            .SelectMany(i => i.Tags)
            .GroupBy(t => t, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(g => g.Key, g => g.Count(), StringComparer.OrdinalIgnoreCase);

        return Kb.Learning
            .Select(m => new TopicStrength(m, Reading.IsModuleComplete(m.Title), m.RelatedTerms.Sum(t => readTagCounts.GetValueOrDefault(t, 0))))
            .Where(x => x.Complete || x.ArticlesRead > 0)
            .OrderByDescending(x => (x.Complete ? 1000 : 0) + x.ArticlesRead)
            .Take(6)
            .ToList();
    }

    private async Task ExportNotes()
    {
        var path = Export.ExportLearningNotes(Kb.Learning);
        Toasts.Show($"Exported to {path}");
        await Task.CompletedTask;
    }

    private HashSet<string> TrendingTags() =>
        History.Items
            .Where(i => i.Published >= DateTimeOffset.UtcNow.AddDays(-14))
            .SelectMany(i => i.Tags)
            .GroupBy(t => t, StringComparer.OrdinalIgnoreCase)
            .Where(g => g.Count() >= 3)
            .Select(g => g.Key)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

    /// <summary>
    /// Trending tags from the last 14 days that no existing module's RelatedTerms already cover - the
    /// "roadmap doesn't have this yet" signal. Pure tag-frequency counting (already used for the course
    /// "Trending" badge above), so this stays genuinely dynamic without needing an AI call to decide
    /// what's new.
    /// </summary>
    private List<string> UncoveredTrendingTags(HashSet<string> trendingTags)
    {
        var covered = Kb.Learning
            .SelectMany(m => m.RelatedTerms)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        return trendingTags
            .Where(t => !covered.Contains(t))
            .OrderBy(t => t, StringComparer.OrdinalIgnoreCase)
            .Take(12)
            .ToList();
    }
}
