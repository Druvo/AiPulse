@page "/glossary"
@attribute [Authorize]
@rendermode InteractiveServer
@inject KnowledgeBaseService Kb
@inject ISummarizer Ai
@inject FeedAggregatorService Feeds
@inject NavigationManager Nav

<PageTitle>AiPulse · Glossary</PageTitle>

<div class="page-header">
    <h1><Icon Name="book" Size="22" /> Glossary</h1>
    <p class="lead">Every buzzword your coworkers throw around — decoded for a developer, with when to actually use it.</p>
</div>

@{
    var emerging = EmergingTerms();
}
@if (emerging.Count > 0)
{
    <div class="card mb-3">
        <div class="card-body">
            <h6 class="section-title mb-2"><Icon Name="sparkle" Size="16" /> Trending in the news, not yet defined here</h6>
            <p class="text-muted small mb-2">Terms showing up often in your News feed that aren't in the glossary yet — queued below for an admin to review, or jump to News to see the coverage yourself.</p>
            <div class="d-flex flex-wrap gap-1">
                @foreach (var (term, count) in emerging)
                {
                    <a class="badge bg-warning text-dark text-decoration-none" href="@($"news?tag={Uri.EscapeDataString(term)}")">@term (@count)</a>
                }
            </div>
        </div>
    </div>
}

<AuthorizeView Roles="Admin" Context="adminPanel">
    <Authorized>
        @if (_pendingCandidates.Count > 0)
        {
            <div class="card mb-3">
                <div class="card-body">
                    <strong class="d-block mb-2"><Icon Name="search" Size="16" /> Candidate terms awaiting review (@_pendingCandidates.Count)</strong>
                    <div class="d-flex flex-column gap-2">
                        @foreach (var c in _pendingCandidates)
                        {
                            @if (_approvingCandidateId == c.Id)
                            {
                                <div class="border rounded p-2">
                                    <EditForm Model="_form" OnValidSubmit="ConfirmApprove">
                                        <div class="row g-2 mb-2">
                                            <div class="col-md-6"><InputText class="form-control form-control-sm" @bind-Value="_form.Term" placeholder="Term" /></div>
                                            <div class="col-md-6">
                                                <InputSelect class="form-select form-select-sm" @bind-Value="_form.Category">
                                                    @foreach (var cat in _categories.Where(c => c != "All"))
                                                    {
                                                        <option value="@cat">@cat</option>
                                                    }
                                                </InputSelect>
                                            </div>
                                        </div>
                                        <InputText class="form-control form-control-sm mb-2" @bind-Value="_form.ShortDef" placeholder="Short definition (required)" />
                                        <InputTextArea class="form-control form-control-sm mb-2" @bind-Value="_form.Details" placeholder="Details (optional)" />
                                        <InputText class="form-control form-control-sm mb-2" @bind-Value="_form.WhenToUse" placeholder="When to use (optional)" />
                                        <InputText class="form-control form-control-sm mb-2" @bind-Value="_form.LearnMoreUrl" placeholder="Learn more URL (optional)" />
                                        @if (_error is not null)
                                        {
                                            <div class="alert alert-danger py-1 px-2 small mb-2">@_error</div>
                                        }
                                        <button type="submit" class="btn btn-sm btn-success">Add to glossary</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => _approvingCandidateId = null">Cancel</button>
                                    </EditForm>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-between gap-2 border rounded p-2">
                                    <div class="small">
                                        <strong>@c.Name</strong>
                                        <span class="text-muted"> — @c.RawNote</span>
                                    </div>
                                    <div class="text-nowrap">
                                        <button class="btn btn-sm btn-outline-success" @onclick="() => StartApprove(c)">Review</button>
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => Dismiss(c.Id)">Dismiss</button>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        }
    </Authorized>
</AuthorizeView>

<input class="form-control mb-2" placeholder="Search a term (e.g. RAG, MCP, loops, headroom, caveman)…"
       @bind="_search" @bind:event="oninput" />

<div class="btn-group mb-3 flex-wrap" role="group">
    @foreach (var cat in _categories)
    {
        <button class="btn btn-sm @(_filter == cat ? "btn-dark" : "btn-outline-dark")"
                @onclick="() => SetCategory(cat)">@cat</button>
    }
</div>

@{
    var matches = Kb.Glossary
        .Where(t => _filter == "All" || t.Category == _filter)
        .Where(t => string.IsNullOrWhiteSpace(_search)
            || t.Term.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || t.Aliases.Any(a => a.Contains(_search, StringComparison.OrdinalIgnoreCase))
            || t.ShortDef.Contains(_search, StringComparison.OrdinalIgnoreCase))
        .OrderBy(t => t.Term)
        .ToList();
}

<p class="text-muted small">@matches.Count of @Kb.Glossary.Count terms</p>

@foreach (var term in matches)
{
    <div class="card mb-2">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-2">
                <h5 class="card-title mb-1">@term.Term</h5>
                <span class="badge bg-info">@term.Category</span>
            </div>
            @if (term.Aliases.Length > 0)
            {
                <p class="small text-muted mb-2">also: @string.Join(", ", term.Aliases)</p>
            }
            <p class="mb-2"><strong>@term.ShortDef</strong></p>
            @if (!string.IsNullOrWhiteSpace(term.Details))
            {
                <p class="mb-2">@term.Details</p>
            }
            @if (!string.IsNullOrWhiteSpace(term.WhenToUse))
            {
                <p class="mb-2"><span class="text-success">When to use:</span> @term.WhenToUse</p>
            }
            @if (term.Related.Length > 0)
            {
                <p class="small mb-1">Related: @string.Join(" · ", term.Related)</p>
            }
            @{
                var mentions = RecentMentions(term.Term);
            }
            @if (mentions.Count > 0)
            {
                <div class="mt-2 mb-2">
                    <p class="x-small text-muted text-uppercase mb-1">Recent mentions</p>
                    @foreach (var m in mentions)
                    {
                        <div class="small">
                            <a href="@m.Link" target="_blank" rel="noopener" class="text-decoration-none">@m.Title</a>
                            <span class="text-muted"> · @m.SourceName</span>
                        </div>
                    }
                    <a href="@($"news?tag={Uri.EscapeDataString(term.Term)}")" class="small">See all in News →</a>
                </div>
            }
            <div class="d-flex gap-3 align-items-center">
                @if (!string.IsNullOrWhiteSpace(term.LearnMoreUrl))
                {
                    <a href="@term.LearnMoreUrl" target="_blank" rel="noopener" class="small">Learn more ↗</a>
                }
                @if (Ai.Enabled)
                {
                    <button class="btn btn-sm btn-outline-primary" @onclick="() => Explain(term.Term)">Explain with AI</button>
                }
            </div>
            @if (_explanations.TryGetValue(term.Term, out var ex))
            {
                <div class="alert alert-light border mt-2 mb-0 small">@ex</div>
            }
        </div>
    </div>
}

@if (matches.Count == 0)
{
    <p>No term matches "<strong>@_search</strong>". Add it to <code>Data/glossary.json</code> and it'll show up here.</p>
}

@code {
    [SupplyParameterFromQuery(Name = "q")]
    public string? QueryParam { get; set; }

    [SupplyParameterFromQuery(Name = "category")]
    public string? CategoryParam { get; set; }

    private string _search = "";
    private string _filter = "All";
    private readonly string[] _categories = { "All", "Concept", "Technique", "Architecture", "Tooling" };
    private readonly Dictionary<string, string> _explanations = new();
    private IReadOnlyList<FeedItem> _feedItems = Array.Empty<FeedItem>();

    private List<ContentCandidate> _pendingCandidates = new();
    private int? _approvingCandidateId;
    private string? _error;
    private GlossaryForm _form = new();

    protected override void OnInitialized()
    {
        if (!string.IsNullOrWhiteSpace(QueryParam))
            _search = QueryParam;
        if (!string.IsNullOrWhiteSpace(CategoryParam) && _categories.Contains(CategoryParam))
            _filter = CategoryParam;

        // Fire-and-forget: the glossary itself renders instantly from static data - it shouldn't block on
        // Feeds.GetAsync(), which on a cold cache can take 10+ minutes with the Reddit source batch. The
        // "emerging terms" panel just fades in once this resolves instead of holding up the whole page.
        _ = LoadFeedItemsAsync();
        _ = RefreshCandidatesAsync();
    }

    private async Task LoadFeedItemsAsync()
    {
        var result = await Feeds.GetAsync();
        _feedItems = result.Items;
        await QueueEmergingCandidatesAsync();
        StateHasChanged();
    }

    /// <summary>Turns the tag-frequency "emerging terms" signal into actual admin-reviewable candidates instead of just a read-only chip list - this is what makes the Glossary "grow on its own."</summary>
    private async Task QueueEmergingCandidatesAsync()
    {
        var existingNames = Kb.Glossary.SelectMany(t => new[] { t.Term }.Concat(t.Aliases)).ToList();
        foreach (var (term, count) in EmergingTerms())
            await Kb.AddContentCandidateIfNewAsync("Glossary", term, "Concept", $"Seen {count}x in News over the last 14 days", existingNames);
        await RefreshCandidatesAsync();
    }

    private async Task RefreshCandidatesAsync() => _pendingCandidates = await Kb.GetPendingContentCandidatesAsync("Glossary");

    private void StartApprove(ContentCandidate c)
    {
        _approvingCandidateId = c.Id;
        _error = null;
        _form = new GlossaryForm { Term = c.Name, Category = c.Category ?? "Concept" };
    }

    private async Task ConfirmApprove()
    {
        if (_approvingCandidateId is null) return;
        if (string.IsNullOrWhiteSpace(_form.Term) || string.IsNullOrWhiteSpace(_form.ShortDef))
        {
            _error = "Term and short definition are required.";
            return;
        }
        await Kb.ApproveGlossaryCandidateAsync(_approvingCandidateId.Value, new GlossaryTerm
        {
            Term = _form.Term.Trim(),
            Category = _form.Category,
            ShortDef = _form.ShortDef.Trim(),
            Details = _form.Details.Trim(),
            WhenToUse = _form.WhenToUse.Trim(),
            LearnMoreUrl = string.IsNullOrWhiteSpace(_form.LearnMoreUrl) ? null : _form.LearnMoreUrl.Trim()
        });
        _approvingCandidateId = null;
        await RefreshCandidatesAsync();
    }

    private async Task Dismiss(int id)
    {
        await Kb.DismissContentCandidateAsync(id);
        await RefreshCandidatesAsync();
    }

    private sealed class GlossaryForm
    {
        public string Term { get; set; } = "";
        public string Category { get; set; } = "Concept";
        public string ShortDef { get; set; } = "";
        public string Details { get; set; } = "";
        public string WhenToUse { get; set; } = "";
        public string LearnMoreUrl { get; set; } = "";
    }

    private void SetCategory(string cat)
    {
        _filter = cat;
        var qs = cat == "All" ? "" : $"?category={Uri.EscapeDataString(cat)}";
        Nav.NavigateTo($"glossary{qs}", replace: true);
    }

    private List<(string Term, int Count)> EmergingTerms()
    {
        var known = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var t in Kb.Glossary)
        {
            known.Add(t.Term);
            foreach (var a in t.Aliases) known.Add(a);
        }

        return _feedItems
            .Where(i => i.Published >= DateTimeOffset.UtcNow.AddDays(-14))
            .SelectMany(i => i.Tags)
            .Where(tag => !string.IsNullOrWhiteSpace(tag) && !known.Contains(tag))
            .GroupBy(tag => tag, StringComparer.OrdinalIgnoreCase)
            .Where(g => g.Count() >= 2)
            .OrderByDescending(g => g.Count())
            .Take(10)
            .Select(g => (g.Key, g.Count()))
            .ToList();
    }

    private List<FeedItem> RecentMentions(string term) =>
        _feedItems
            .Where(i => i.Tags.Contains(term, StringComparer.OrdinalIgnoreCase))
            .OrderByDescending(i => i.Published)
            .Take(3)
            .ToList();

    private async Task Explain(string term)
    {
        var text = await Ai.ExplainTermAsync(term);
        if (text is not null)
            _explanations[term] = text;
    }
}
