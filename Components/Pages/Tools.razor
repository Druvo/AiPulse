@page "/tools"
@attribute [Authorize]
@rendermode InteractiveServer
@inject KnowledgeBaseService Kb
@inject GitHubTrendingService GitHub

<PageTitle>AiPulse · Tools &amp; Tips</PageTitle>

<div class="page-header">
    <h1><Icon Name="tool" Size="22" /> Tools &amp; Tips</h1>
    <p class="lead">The right tool for the right task, plus concrete ways to cut token usage.</p>
</div>

<AuthorizeView Roles="Admin,Curator" Context="adminPanel">
    <Authorized>
        @if (_pendingCandidates.Count > 0)
        {
            <div class="card mb-3">
                <div class="card-body">
                    <strong class="d-block mb-2"><Icon Name="search" Size="16" /> Candidate tools awaiting review (@_pendingCandidates.Count)</strong>
                    <div class="d-flex flex-column gap-2">
                        @foreach (var c in _pendingCandidates)
                        {
                            @if (_approvingCandidateId == c.Id)
                            {
                                <div class="border rounded p-2">
                                    <EditForm Model="_form" OnValidSubmit="ConfirmApprove">
                                        <div class="row g-2 mb-2">
                                            <div class="col-md-6"><InputText class="form-control form-control-sm" @bind-Value="_form.Name" placeholder="Name" /></div>
                                            <div class="col-md-6"><InputText class="form-control form-control-sm" @bind-Value="_form.Category" placeholder="Category" /></div>
                                        </div>
                                        <InputText class="form-control form-control-sm mb-2" @bind-Value="_form.OneLiner" placeholder="One-liner (required)" />
                                        <InputText class="form-control form-control-sm mb-2" @bind-Value="_form.BestFor" placeholder="Best for (comma-separated)" />
                                        <InputText class="form-control form-control-sm mb-2" @bind-Value="_form.NotIdealFor" placeholder="Not ideal for (comma-separated)" />
                                        <InputText class="form-control form-control-sm mb-2" @bind-Value="_form.TokenTips" placeholder="Token tips (comma-separated)" />
                                        <InputText class="form-control form-control-sm mb-2" @bind-Value="_form.Url" placeholder="URL" />
                                        @if (_error is not null)
                                        {
                                            <div class="alert alert-danger py-1 px-2 small mb-2">@_error</div>
                                        }
                                        <button type="submit" class="btn btn-sm btn-success">Add to list</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => _approvingCandidateId = null">Cancel</button>
                                    </EditForm>
                                </div>
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-between gap-2 border rounded p-2">
                                    <div class="small">
                                        <strong>@c.Name</strong>
                                        <span class="text-muted"> — @c.RawNote</span>
                                    </div>
                                    <div class="text-nowrap">
                                        <button class="btn btn-sm btn-outline-success" @onclick="() => StartApprove(c)">Review</button>
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => Dismiss(c.Id)">Dismiss</button>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        }
    </Authorized>
</AuthorizeView>

<h3 class="section-title mt-4"><Icon Name="tool" Size="18" /> Right tool for the right task</h3>

<FilterBar>
    <input class="form-control form-control-sm" style="max-width:260px" placeholder="Search tools…"
           value="@_search" @oninput="e => { _search = (string)e.Value!; _page = 1; }" />
    <select class="form-select form-select-sm w-auto" @bind="_category" @bind:after="() => _page = 1">
        <option value="">All categories</option>
        @foreach (var c in Kb.Tools.Select(t => t.Category).Distinct().OrderBy(c => c))
        {
            <option value="@c">@c</option>
        }
    </select>
    <select class="form-select form-select-sm w-auto" @bind="_sort" @bind:after="() => _page = 1">
        <option value="category">Category (default)</option>
        <option value="popularity">Popularity (live GitHub stars)</option>
        <option value="name">Name A-Z</option>
    </select>
</FilterBar>

@{
    var (pagedTools, totalTools) = GetPage();
}
<p class="text-muted small">@totalTools tool(s)</p>

@if (totalTools == 0)
{
    <EmptyState Icon="search" Title="No tools match the current filter/search" ActionText="Clear filters" OnAction="@(() => { _search = ""; _category = ""; _page = 1; })" />
}
else if (_sort == "category")
{
    @foreach (var group in pagedTools.GroupBy(t => t.Category))
    {
        <h5 class="mt-3 text-muted">@group.Key</h5>
        @foreach (var tool in group)
        {
            @ToolCard(tool)
        }
    }
}
else
{
    @foreach (var tool in pagedTools)
    {
        @ToolCard(tool)
    }
}

@if (totalTools > 0)
{
    <Pager TotalItems="totalTools" @bind-CurrentPage="_page" @bind-PageSize="_pageSize" PageSizeOptions="new[] { 10, 20, 50 }" />
}

<h3 class="section-title mt-5"><Icon Name="sparkle" Size="18" /> Best practices &amp; token optimization</h3>
@foreach (var group in Kb.Practices.GroupBy(p => p.Category))
{
    <h5 class="mt-3 text-muted">@group.Key</h5>
    <div class="row g-2">
        @foreach (var tip in group)
        {
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-body py-2">
                        <h6 class="card-title mb-1">@tip.Title</h6>
                        <p class="card-text small mb-0">@tip.Body</p>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<TrendingRepo> _trendingRepos = new();
    private Dictionary<string, int> _starCounts = new();

    private string _search = "";
    private string _category = "";
    private string _sort = "category";
    private int _page = 1;
    private int _pageSize = 10;

    protected override void OnInitialized()
    {
        // Independent loads - a slow/unreachable GitHub trending fetch shouldn't hold up the popularity
        // badges on the curated tools list below (or vice versa).
        _ = LoadTrendingReposAsync();
        _ = LoadStarCountsAsync();
        _ = RefreshCandidatesAsync();
    }

    /// <summary>No display panel for this anymore - the fetch only feeds QueueToolCandidatesAsync's candidate detection below.</summary>
    private async Task LoadTrendingReposAsync()
    {
        _trendingRepos = await GitHub.GetTrendingReposAsync();
        await QueueToolCandidatesAsync();
    }

    private static readonly string[] AiToolKeywords =
    {
        "ai", "llm", "gpt", "agent", "copilot", "assistant", "chatbot", "rag", "prompt",
        "claude", "openai", "ollama", "langchain", "vector", "embedding", "coding agent"
    };

    /// <summary>
    /// Trending repos not already on the curated list (by name/URL), filtered to ones that look like
    /// AI-dev-tooling by keyword match on name/description - the closest deterministic substitute for "is
    /// this actually relevant to this page" without an AI call to judge it.
    /// </summary>
    private async Task QueueToolCandidatesAsync()
    {
        var existingNames = Kb.Tools.Select(t => t.Name).Concat(Kb.Tools.Select(t => t.Url ?? "")).ToList();
        var candidates = _trendingRepos
            .Where(r => AiToolKeywords.Any(k =>
                r.FullName.Contains(k, StringComparison.OrdinalIgnoreCase) ||
                (r.Description?.Contains(k, StringComparison.OrdinalIgnoreCase) ?? false)))
            .Take(20);

        foreach (var r in candidates)
            await Kb.AddContentCandidateIfNewAsync("Tool", r.FullName, "Coding Agent", r.Description ?? r.Url, existingNames);

        await RefreshCandidatesAsync();
    }

    private List<ContentCandidate> _pendingCandidates = new();
    private int? _approvingCandidateId;
    private string? _error;
    private ToolForm _form = new();

    private async Task RefreshCandidatesAsync() => _pendingCandidates = await Kb.GetPendingContentCandidatesAsync("Tool");

    private void StartApprove(ContentCandidate c)
    {
        _approvingCandidateId = c.Id;
        _error = null;
        _form = new ToolForm { Name = c.Name, Category = c.Category ?? "Coding Agent", Url = c.RawNote?.StartsWith("http") == true ? c.RawNote : "" };
    }

    private async Task ConfirmApprove()
    {
        if (_approvingCandidateId is null) return;
        if (string.IsNullOrWhiteSpace(_form.Name) || string.IsNullOrWhiteSpace(_form.OneLiner))
        {
            _error = "Name and one-liner are required.";
            return;
        }
        static string[] Split(string s) => s.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        await Kb.ApproveToolCandidateAsync(_approvingCandidateId.Value, new ToolEntry
        {
            Name = _form.Name.Trim(),
            Category = _form.Category.Trim(),
            OneLiner = _form.OneLiner.Trim(),
            BestFor = Split(_form.BestFor),
            NotIdealFor = Split(_form.NotIdealFor),
            TokenTips = Split(_form.TokenTips),
            Url = string.IsNullOrWhiteSpace(_form.Url) ? null : _form.Url.Trim()
        });
        _approvingCandidateId = null;
        await RefreshCandidatesAsync();
    }

    private async Task Dismiss(int id)
    {
        await Kb.DismissContentCandidateAsync(id);
        await RefreshCandidatesAsync();
    }

    private sealed class ToolForm
    {
        public string Name { get; set; } = "";
        public string Category { get; set; } = "Coding Agent";
        public string OneLiner { get; set; } = "";
        public string BestFor { get; set; } = "";
        public string NotIdealFor { get; set; } = "";
        public string TokenTips { get; set; } = "";
        public string Url { get; set; } = "";
    }

    private async Task LoadStarCountsAsync()
    {
        var lookups = Kb.Tools
            .Select(t => (Tool: t, Repo: ParseGitHubUrl(t.Url)))
            .Where(x => x.Repo is not null)
            .ToList();

        var results = await Task.WhenAll(lookups.Select(async x =>
        {
            var stars = await GitHub.GetRepoStatsAsync(x.Repo!.Value.Owner, x.Repo.Value.Repo);
            return (x.Tool.Name, Stars: stars);
        }));

        _starCounts = results.Where(r => r.Stars.HasValue).ToDictionary(r => r.Name, r => r.Stars!.Value);
        StateHasChanged();
    }

    /// <summary>Extracts (owner, repo) from a tool's Url if it points at a github.com repo - used to look up a live star count for the "Popularity" sort/badge.</summary>
    private static (string Owner, string Repo)? ParseGitHubUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return null;
        if (!Uri.TryCreate(url, UriKind.Absolute, out var uri) || !uri.Host.Equals("github.com", StringComparison.OrdinalIgnoreCase))
            return null;

        var parts = uri.AbsolutePath.Trim('/').Split('/', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2 ? (parts[0], parts[1]) : null;
    }

    private static string FormatStars(int n) => n >= 1000 ? (n / 1000.0).ToString("0.#") + "k" : n.ToString("N0");

    private (List<ToolEntry> Tools, int Total) GetPage()
    {
        IEnumerable<ToolEntry> q = Kb.Tools;

        if (!string.IsNullOrEmpty(_category))
            q = q.Where(t => t.Category == _category);

        if (!string.IsNullOrWhiteSpace(_search))
        {
            var s = _search.Trim();
            q = q.Where(t =>
                t.Name.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                t.OneLiner.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                t.BestFor.Any(b => b.Contains(s, StringComparison.OrdinalIgnoreCase)));
        }

        q = _sort switch
        {
            "popularity" => q.OrderByDescending(t => _starCounts.TryGetValue(t.Name, out var s) ? s : -1),
            "name" => q.OrderBy(t => t.Name, StringComparer.OrdinalIgnoreCase),
            _ => q.OrderBy(t => t.Category, StringComparer.OrdinalIgnoreCase).ThenBy(t => t.Name, StringComparer.OrdinalIgnoreCase),
        };

        var list = q.ToList();
        var page = list.Skip((_page - 1) * _pageSize).Take(_pageSize).ToList();
        return (page, list.Count);
    }

    private RenderFragment ToolCard(ToolEntry tool) => @<div class="card mb-2">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-2">
                <h5 class="card-title mb-1">
                    @if (!string.IsNullOrWhiteSpace(tool.Url))
                    {
                        <a href="@tool.Url" target="_blank" rel="noopener" class="text-decoration-none">@tool.Name ↗</a>
                    }
                    else
                    {
                        @tool.Name
                    }
                </h5>
                @if (_starCounts.TryGetValue(tool.Name, out var stars))
                {
                    <span class="badge bg-secondary text-nowrap" title="Live GitHub star count">★ @FormatStars(stars)</span>
                }
            </div>
            <p class="mb-2">@tool.OneLiner</p>
            <div class="row">
                <div class="col-md-6">
                    <div class="small text-success fw-bold">Best for</div>
                    <ul class="small">
                        @foreach (var b in tool.BestFor) { <li>@b</li> }
                    </ul>
                </div>
                <div class="col-md-6">
                    <div class="small text-danger fw-bold">Not ideal for</div>
                    <ul class="small">
                        @foreach (var n in tool.NotIdealFor) { <li>@n</li> }
                    </ul>
                </div>
            </div>
            @if (tool.TokenTips.Length > 0)
            {
                <div class="small text-primary fw-bold">Token tips</div>
                <ul class="small mb-0">
                    @foreach (var tip in tool.TokenTips) { <li>@tip</li> }
                </ul>
            }
        </div>
    </div>;
}
