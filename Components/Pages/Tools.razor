@page "/tools"
@attribute [Authorize]
@rendermode InteractiveServer
@inject KnowledgeBaseService Kb
@inject GitHubTrendingService GitHub

<PageTitle>AiPulse · Tools &amp; Tips</PageTitle>

<div class="page-header">
    <h1><Icon Name="tool" Size="22" /> Tools &amp; Tips</h1>
    <p class="lead">The right tool for the right task, plus concrete ways to cut token usage.</p>
</div>

@if (_trendingRepos.Count > 0)
{
    <div class="card mb-4">
        <div class="card-body">
            <h6 class="section-title mb-2"><Icon Name="sparkle" Size="16" /> Trending dev tools &amp; frameworks</h6>
            <p class="text-muted small mb-2">Recently popular AI repos, via GitHub's search API — refreshes hourly. The curated list below is hand-picked; this is what's new.</p>
            <div class="row g-2">
                @foreach (var r in _trendingRepos.Take(8))
                {
                    <div class="col-md-6">
                        <a href="@r.Url" target="_blank" rel="noopener" class="d-block small text-decoration-none border-bottom py-1">
                            @r.FullName
                            <span class="text-muted"> · ★ @r.Stars.ToString("N0")@(string.IsNullOrWhiteSpace(r.Language) ? "" : $" · {r.Language}")</span>
                        </a>
                    </div>
                }
            </div>
            <a href="explore?tab=repos" class="small">See all trending repos →</a>
        </div>
    </div>
}

<h3 class="section-title mt-4"><Icon Name="tool" Size="18" /> Right tool for the right task</h3>
@foreach (var group in Kb.Tools.GroupBy(t => t.Category))
{
    <h5 class="mt-3 text-muted">@group.Key</h5>
    @foreach (var tool in group)
    {
        <div class="card mb-2">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start gap-2">
                    <h5 class="card-title mb-1">
                        @if (!string.IsNullOrWhiteSpace(tool.Url))
                        {
                            <a href="@tool.Url" target="_blank" rel="noopener" class="text-decoration-none">@tool.Name ↗</a>
                        }
                        else
                        {
                            @tool.Name
                        }
                    </h5>
                </div>
                <p class="mb-2">@tool.OneLiner</p>
                <div class="row">
                    <div class="col-md-6">
                        <div class="small text-success fw-bold">Best for</div>
                        <ul class="small">
                            @foreach (var b in tool.BestFor) { <li>@b</li> }
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <div class="small text-danger fw-bold">Not ideal for</div>
                        <ul class="small">
                            @foreach (var n in tool.NotIdealFor) { <li>@n</li> }
                        </ul>
                    </div>
                </div>
                @if (tool.TokenTips.Length > 0)
                {
                    <div class="small text-primary fw-bold">Token tips</div>
                    <ul class="small mb-0">
                        @foreach (var tip in tool.TokenTips) { <li>@tip</li> }
                    </ul>
                }
            </div>
        </div>
    }
}

<h3 class="section-title mt-5"><Icon Name="sparkle" Size="18" /> Best practices &amp; token optimization</h3>
@foreach (var group in Kb.Practices.GroupBy(p => p.Category))
{
    <h5 class="mt-3 text-muted">@group.Key</h5>
    <div class="row g-2">
        @foreach (var tip in group)
        {
            <div class="col-md-6">
                <div class="card h-100">
                    <div class="card-body py-2">
                        <h6 class="card-title mb-1">@tip.Title</h6>
                        <p class="card-text small mb-0">@tip.Body</p>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<TrendingRepo> _trendingRepos = new();

    protected override async Task OnInitializedAsync()
    {
        _trendingRepos = await GitHub.GetTrendingReposAsync();
    }
}
