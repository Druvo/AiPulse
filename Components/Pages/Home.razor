@page "/"
@attribute [Authorize]
@rendermode InteractiveServer
@inject KnowledgeBaseService Kb
@inject ReadingStateService Reading
@inject ISummarizer Ai
@inject FeedAggregatorService Feeds
@inject FeedHistoryService History
@inject HuggingFaceService HuggingFace
@inject GitHubTrendingService GitHubTrending
@inject NavigationManager Nav

<PageTitle>AiPulse · Dashboard</PageTitle>

<div class="page-header">
    <h1><Icon Name="zap" Size="22" /> Dashboard</h1>
    <p class="lead">Your everyday station to read the AI world and level up as a developer — news, jargon, tools, and a learning roadmap. Runs standalone, no AI required.</p>
</div>

@if (!_welcomeDismissed)
{
    <div class="card mb-4 welcome-banner">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-3">
                <div>
                    <h5 class="mb-1"><Icon Name="sparkle" Size="18" /> New here?</h5>
                    <p class="mb-2">
                        AiPulse aggregates ~51 AI news/research/tool sources into one feed, plus a glossary, a tools
                        comparison, and a learning roadmap — all standalone, no AI required to run it.
                    </p>
                    <a href="help" class="btn btn-sm btn-primary">
                        <Icon Name="help-circle" Size="14" /> Read the full guide
                    </a>
                </div>
                <button class="btn btn-sm btn-link text-muted" @onclick="DismissWelcome" title="Dismiss">
                    <Icon Name="check" Size="16" /> Got it
                </button>
            </div>
        </div>
    </div>
}

<div class="row g-3 mb-4 row-cols-2 row-cols-lg-5">
    <div class="col">
        <a class="stat-card" href="news?filter=New">
            <div class="stat-num">@_newSinceVisit</div>
            <div class="stat-label"><Icon Name="rss" Size="14" /> New since last visit</div>
        </a>
    </div>
    <div class="col">
        <a class="stat-card" href="news">
            <div class="stat-num">@Kb.Sources.Count(s => s.Enabled)</div>
            <div class="stat-label"><Icon Name="rss" Size="14" /> Live sources</div>
        </a>
    </div>
    <div class="col">
        <a class="stat-card" href="glossary">
            <div class="stat-num">@Kb.Glossary.Count</div>
            <div class="stat-label"><Icon Name="book" Size="14" /> Glossary terms</div>
        </a>
    </div>
    <div class="col">
        <a class="stat-card" href="learn">
            <div class="stat-num">@Kb.Learning.Count</div>
            <div class="stat-label"><Icon Name="graduation-cap" Size="14" /> Learning modules</div>
        </a>
    </div>
    <div class="col">
        <a class="stat-card" href="bookmarks">
            <div class="stat-num">@Reading.Bookmarks.Count</div>
            <div class="stat-label"><Icon Name="bookmark" Size="14" /> Saved to read</div>
        </a>
    </div>
</div>

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <h4 class="section-title mb-0"><Icon Name="calendar" /> Digest</h4>
    <div class="btn-group btn-group-sm" role="group">
        <button class="btn @(_range == "today" ? "btn-dark" : "btn-outline-dark")" @onclick='() => SetRange("today")'>Today</button>
        <button class="btn @(_range == "week" ? "btn-dark" : "btn-outline-dark")" @onclick='() => SetRange("week")'>This Week</button>
        <button class="btn @(_range == "month" ? "btn-dark" : "btn-outline-dark")" @onclick='() => SetRange("month")'>This Month</button>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-num">@_rangeItems.Count</div>
            <div class="stat-label"><Icon Name="rss" Size="14" /> Items @RangeLabel</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-num">@_activeSourceCount</div>
            <div class="stat-label"><Icon Name="database" Size="14" /> Active sources</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-num">@(_topCategory ?? "—")</div>
            <div class="stat-label"><Icon Name="trending-up" Size="14" /> Top category</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-num">@_multiSourceStories.Count</div>
            <div class="stat-label"><Icon Name="star" Size="14" /> Multi-source stories</div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-4">
        <TrendingPanel Items="_rangeItems" DaysWindow="_daysWindow" />
    </div>
    <div class="col-lg-4">
        <MiniTimeline Items="_historyItems ?? Array.Empty<FeedItem>()" MaxDays="_heatmapDays" />
    </div>
    <div class="col-lg-4">
        <ExploreTrendingPanel Models="_trendingModels" Repos="_trendingRepos" Developers="_trendingDevelopers" Loading="_trendingLoading" OnRefresh="() => LoadTrendingAsync(force: true)" />
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <h4 class="section-title"><Icon Name="star" /> Biggest story @RangeLabel</h4>
        @if (_biggestStory is not null)
        {
            <FeedItemCard Item="_biggestStory" Layout="Compact" CssClass="biggest-story-card" />
        }
        else
        {
            <p class="text-muted">Not enough data yet — check back after AiPulse has been running a few days.</p>
        }
    </div>
    <div class="col-md-6">
        @if (_range != "today")
        {
            <h4 class="section-title"><Icon Name="calendar" /> Day by day</h4>

            <div class="mb-2">
                <input class="form-control form-control-sm" style="max-width:280px" placeholder="Search by category…"
                       value="@_search" @oninput="e => { _search = (string)e.Value!; _dayPage = 1; }" />
            </div>

            var (pageDays, totalDays) = GetDayPage();

            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <SortableHeader Column="date" Label="Day" SortColumn="@_sortColumn" SortAscending="@_sortAscending" OnSort="ToggleSort" />
                            <SortableHeader Column="count" Label="Items" SortColumn="@_sortColumn" SortAscending="@_sortAscending" OnSort="ToggleSort" />
                            <th>Top categories</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var day in pageDays)
                        {
                            <tr>
                                <td>@day.Date.ToString("ddd, MMM d")</td>
                                <td>@day.Count</td>
                                <td>
                                    @foreach (var (cat, count) in day.TopCategories)
                                    {
                                        <span class="badge bg-secondary me-1">@cat @count</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <Pager TotalItems="totalDays" @bind-CurrentPage="_dayPage" @bind-PageSize="_dayPageSize" PageSizeOptions="new[] { 7, 14, 30 }" />
        }
    </div>
</div>

<h4 class="section-title"><Icon Name="star" /> Biggest stories @RangeLabel</h4>
<p class="text-muted">Ranked by how many of your sources covered the same story — the more sources reporting it, the bigger the signal.</p>

@{
    // The single biggest story already got its own hero card above - don't repeat it as the list's first entry too.
    var otherBiggestStories = _biggestStories.Where(i => i.Link != _biggestStory?.Link).ToList();
}
@if (otherBiggestStories.Count == 0)
{
    <p class="text-muted">Not enough data yet — check back after AiPulse has been running a few days.</p>
}
else
{
    @foreach (var item in otherBiggestStories)
    {
        <div class="mb-2">
            <FeedItemCard Item="item" Layout="Compact" />
        </div>
    }
}

@if (Reading.DashboardWidgets.Count > 0)
{
    <div class="row g-4 mb-4">
        @foreach (var w in Reading.DashboardWidgets)
        {
            <div class="col-lg-6">
                <h4 class="section-title">@w.Title</h4>
                @if (w.Type == "Iframe")
                {
                    <div class="card">
                        <iframe src="@w.Content" class="dashboard-widget-frame" sandbox="allow-scripts allow-same-origin allow-popups"></iframe>
                    </div>
                }
                else
                {
                    <div class="card">
                        <div class="card-body">@((MarkupString)w.Content)</div>
                    </div>
                }
            </div>
        }
    </div>
}

<div class="row g-4">
    <div class="col-lg-7">
        <h4 class="section-title"><Icon Name="graduation-cap" /> Continue learning</h4>
        <p class="text-muted">@Reading.CompletedModuleCount of @Kb.Learning.Count modules complete. Pick up where you left off.</p>
        @{
            var next = Kb.Learning.Where(m => !Reading.IsModuleComplete(m.Title)).Take(4).ToList();
        }
        @if (next.Count == 0)
        {
            <p class="text-success">All modules complete.</p>
        }
        else
        {
            @foreach (var m in next)
            {
                <a class="card mb-2 text-decoration-none" href="learn">
                    <div class="card-body py-2 d-flex justify-content-between align-items-center">
                        <span>@m.Title</span>
                        <span class="badge level-@m.Level.ToLower()">@m.Level</span>
                    </div>
                </a>
            }
        }
        <a href="learn" class="btn btn-sm btn-outline-primary mt-1">See all @Kb.Learning.Count modules →</a>
    </div>

    <div class="col-lg-5">
        <h4 class="section-title"><Icon Name="bookmark" /> Read later</h4>
        @if (Reading.Bookmarks.Count == 0)
        {
            <p class="text-muted">Nothing saved yet. On the <a href="news">News Feed</a>, click the tag icon on any article to save it here.</p>
        }
        else
        {
            @foreach (var b in Reading.Bookmarks.Take(6))
            {
                <div class="mb-2">
                    <FeedItemCard Item="ToFeedItem(b)" Layout="Compact" />
                </div>
            }
            <a href="bookmarks" class="btn btn-sm btn-outline-primary mt-1">Open reading list →</a>
        }

        <div class="alert @(Ai.Enabled ? "alert-success" : "alert-secondary") mt-3 small">
            <strong>AI layer:</strong>
            @(Ai.Enabled ? "Enabled." : "Off (standalone). Plug in Claude later via ISummarizer.")
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "range")]
    public string? RangeParam { get; set; }

    private static readonly HashSet<string> ValidRanges = new() { "today", "week", "month" };

    private IReadOnlyList<FeedItem>? _historyItems;
    private bool _welcomeDismissed;
    private List<TrendingModel> _trendingModels = new();
    private List<TrendingRepo> _trendingRepos = new();
    private List<TrendingDeveloper> _trendingDevelopers = new();
    private bool _trendingLoading = true;
    private int _newSinceVisit;
    private FeedItem? _biggestStory;

    private string _range = "week";
    private List<FeedItem> _rangeItems = new();
    private int _activeSourceCount;
    private string? _topCategory;
    private List<FeedItem> _multiSourceStories = new();
    private List<FeedItem> _biggestStories = new();
    private List<DayRow> _byDay = new();

    private string _search = "";
    private string? _sortColumn = "date";
    private bool _sortAscending = false;
    private int _dayPage = 1;
    private int _dayPageSize = 7;

    private int _daysWindow => _range switch { "today" => 1, "month" => 30, _ => 7 };
    private int _heatmapDays => _range switch { "today" => 7, "month" => 90, _ => 30 };
    private string RangeLabel => _range switch { "today" => "today", "month" => "this month", _ => "this week" };

    protected override void OnInitialized()
    {
        if (!string.IsNullOrWhiteSpace(RangeParam) && ValidRanges.Contains(RangeParam))
            _range = RangeParam;

        _welcomeDismissed = Reading.WelcomeDismissed;
        _historyItems = History.Items; // already-persisted (FeedHistoryService) - no async needed, renders immediately
        RecomputeRange();

        // Both third-party lookups load independently in the background instead of gating the whole
        // Dashboard behind one shared wait - a slow/unreachable Hugging Face or GitHub no longer holds up
        // everything else on the page (stat cards, trending panel, biggest stories all render right away).
        _ = LoadNewSinceVisitAsync();
        _ = LoadTrendingAsync();
    }

    private async Task LoadNewSinceVisitAsync()
    {
        var result = await Feeds.GetAsync(); // warms the shared cache other pages read from
        // Same live-cache source News.razor's own "New" filter counts against - History.Items (90-day
        // persisted log) would disagree with what clicking through to News actually shows.
        _newSinceVisit = result.Items.Count(i => i.Published > Reading.LastNewsVisit);
        StateHasChanged();
    }

    private async Task LoadTrendingAsync(bool force = false)
    {
        _trendingLoading = true;
        StateHasChanged();
        try
        {
            var hfTask = HuggingFace.GetTrendingAsync(force);
            var reposTask = GitHubTrending.GetTrendingReposAsync(force: force);
            var devsTask = GitHubTrending.GetTrendingDevelopersAsync(force: force);
            await Task.WhenAll(hfTask, reposTask, devsTask);
            (_trendingModels, _) = hfTask.Result;
            _trendingRepos = reposTask.Result;
            _trendingDevelopers = devsTask.Result;
        }
        finally
        {
            _trendingLoading = false;
            StateHasChanged();
        }
    }

    private void SetRange(string range)
    {
        _range = range;
        _dayPage = 1;
        RecomputeRange();
        Nav.NavigateTo(range == "week" ? "/" : $"/?range={range}", replace: true);
    }

    /// <summary>Re-derives every range-scoped section (stat cards, trending panel, biggest stories, day-by-day) from the currently selected Today/Week/Month range - mirrors what Digest.razor used to compute for a hardcoded 7 days.</summary>
    private void RecomputeRange()
    {
        if (_historyItems is null) return;

        var cutoff = _range switch
        {
            "today" => new DateTimeOffset(DateTime.Today),
            "month" => DateTimeOffset.Now.AddDays(-30),
            _ => DateTimeOffset.Now.AddDays(-7),
        };
        _rangeItems = _historyItems.Where(i => i.Published >= cutoff).ToList();

        _activeSourceCount = _rangeItems.Select(i => i.SourceName).Distinct(StringComparer.OrdinalIgnoreCase).Count();
        _topCategory = _rangeItems.GroupBy(i => i.Category)
            .OrderByDescending(g => g.Count())
            .Select(g => g.Key)
            .FirstOrDefault();

        _multiSourceStories = _rangeItems.Where(i => i.AlsoSeenOn.Length > 0).ToList();
        _biggestStories = _rangeItems
            .OrderByDescending(i => i.AlsoSeenOn.Length)
            .ThenByDescending(i => i.Published)
            .Take(10)
            .ToList();
        _biggestStory = _biggestStories.FirstOrDefault(i => i.AlsoSeenOn.Length > 0);

        _byDay = _rangeItems
            .GroupBy(i => i.Published.LocalDateTime.Date)
            .OrderByDescending(g => g.Key)
            .Select(g => new DayRow
            {
                Date = g.Key,
                Count = g.Count(),
                TopCategories = g.GroupBy(i => i.Category)
                    .OrderByDescending(c => c.Count())
                    .Take(3)
                    .Select(c => (c.Key, c.Count()))
                    .ToList()
            })
            .ToList();
    }

    private void ToggleSort(string column)
    {
        if (_sortColumn == column) _sortAscending = !_sortAscending;
        else { _sortColumn = column; _sortAscending = true; }
        _dayPage = 1;
    }

    private (List<DayRow> Rows, int Total) GetDayPage()
    {
        IEnumerable<DayRow> q = _byDay;

        if (!string.IsNullOrWhiteSpace(_search))
        {
            var needle = _search.Trim();
            q = q.Where(d => d.TopCategories.Any(c => c.Category.Contains(needle, StringComparison.OrdinalIgnoreCase)));
        }

        q = (_sortColumn, _sortAscending) switch
        {
            ("date", true) => q.OrderBy(d => d.Date),
            ("count", true) => q.OrderBy(d => d.Count),
            ("count", false) => q.OrderByDescending(d => d.Count),
            (_, false) => q.OrderByDescending(d => d.Date),
            _ => q.OrderBy(d => d.Date),
        };

        var list = q.ToList();
        var page = list.Skip((_dayPage - 1) * _dayPageSize).Take(_dayPageSize).ToList();
        return (page, list.Count);
    }

    private sealed class DayRow
    {
        public DateTime Date { get; set; }
        public int Count { get; set; }
        public List<(string Category, int Count)> TopCategories { get; set; } = new();
    }

    private void DismissWelcome()
    {
        Reading.DismissWelcome();
        _welcomeDismissed = true;
    }

    /// <summary>Adapts a saved BookmarkItem to a FeedItem so it can render through the shared FeedItemCard.</summary>
    private static FeedItem ToFeedItem(BookmarkItem b) => new()
    {
        Title = b.Title,
        Link = b.Link,
        SourceName = b.SourceName,
        Category = b.Category,
        ContentType = b.ContentType,
        Level = b.Level,
        Tags = b.Tags,
        Published = b.SavedAt,
        Summary = b.Summary ?? "",
        ImageUrl = b.ImageUrl
    };
}
