@page "/news"
@attribute [Authorize]
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject FeedAggregatorService Feeds
@inject ReadingStateService Reading
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>AiPulse · News Feed</PageTitle>

<div class="news-layout">
<div class="news-main">
<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h1 class="mb-0"><Icon Name="rss" Size="22" /> News Feed</h1>
    <div class="d-flex align-items-center gap-2">
        @if (_result is not null)
        {
            <span class="text-muted small">Updated @_result.FetchedAt.ToLocalTime().ToString("g")</span>
        }
        <div class="btn-group view-toggle" role="group">
            <button class="btn btn-sm @(_view == "List" ? "btn-dark" : "btn-outline-dark")" @onclick='() => SetView("List")'><Icon Name="list" Size="15" /> List</button>
            <button class="btn btn-sm @(_view == "Grid" ? "btn-dark" : "btn-outline-dark")" @onclick='() => SetView("Grid")'><Icon Name="grid" Size="15" /> Grid</button>
        </div>
        <button class="btn btn-primary" @onclick="() => Load(true)" disabled="@_loading">
            @if (_loading)
            {
                <span class="spinner"></span>
            }
            else
            {
                <Icon Name="refresh" Size="15" />
            }
            @(_loading ? "Refreshing…" : "Refresh")
        </button>
        <button class="btn btn-sm btn-outline-dark" title="Keyboard shortcuts" @onclick="() => _showShortcutsHelp = !_showShortcutsHelp">?</button>
    </div>
</div>

@if (_showShortcutsHelp)
{
    <div class="alert alert-light border small mb-3">
        <strong>Keyboard shortcuts</strong> (inactive while typing in a text field):
        <code>j</code>/<code>k</code> move focus down/up ·
        <code>o</code>/<code>Enter</code> open focused item ·
        <code>m</code> toggle read ·
        <code>b</code> toggle bookmark ·
        <code>r</code> refresh ·
        <code>?</code> toggle this help ·
        <code>Esc</code> clear focus
    </div>
}

<input class="form-control mb-3" placeholder="Search the feed…" value="@_search" @oninput="e => { _search = (string)e.Value!; _page = 1; }" />

<div class="d-flex flex-wrap align-items-center gap-2 mb-2">
    <div class="btn-group flex-wrap" role="group">
        @foreach (var f in _filters)
        {
            <button class="btn btn-sm @(_filter == f ? "btn-dark" : "btn-outline-dark")"
                    @onclick="() => SetFilter(f)">
                @f
                @if (f == "New" && _newCount > 0)
                {
                    <span class="badge bg-info ms-1">@_newCount</span>
                }
            </button>
        }
    </div>
    <button class="btn btn-sm btn-outline-dark" @onclick="() => _showFilters = !_showFilters">
        <Icon Name="tool" Size="14" /> Filters
        @if (ActiveFilterCount() > 0)
        {
            <span class="badge bg-info ms-1">@ActiveFilterCount()</span>
        }
    </button>
    @if (!string.IsNullOrEmpty(_tag))
    {
        <button class="btn btn-sm btn-warning" @onclick='() => SetTag("")'>Tag: @_tag ✕</button>
    }
    @if (_dateFrom is not null && _dateTo is not null)
    {
        <button class="btn btn-sm btn-warning" @onclick="ClearDate">
            @(_dateFrom == _dateTo ? $"Day: {_dateFrom.Value:MMM d}" : $"{_dateFrom.Value:MMM d} – {_dateTo.Value:MMM d}") ✕
        </button>
    }
    @if (_sources.Count > 0)
    {
        <button class="btn btn-sm btn-warning" @onclick="ClearSources">Sources (@_sources.Count) ✕</button>
    }
</div>

@if (_showFilters)
{
    <div class="d-flex flex-wrap gap-2 mb-2">
        <select class="form-select form-select-sm w-auto" @bind="_contentType" @bind:after="SyncUrl">
            <option value="">All content types</option>
            @foreach (var ct in _contentTypes)
            {
                <option value="@ct">@ct</option>
            }
        </select>
        <select class="form-select form-select-sm w-auto" @bind="_level" @bind:after="SyncUrl">
            <option value="">All levels</option>
            @foreach (var lvl in _levels)
            {
                <option value="@lvl">@lvl</option>
            }
        </select>
        <select class="form-select form-select-sm w-auto" @bind="_sort" @bind:after="SyncUrl">
            <option value="newest">Newest first</option>
            <option value="oldest">Oldest first</option>
            <option value="source">Source A-Z</option>
            <option value="title">Title A-Z</option>
        </select>
    </div>

    @if (AvailableSources().Count > 0)
    {
        <div class="mb-2">
            <div class="x-small text-muted text-uppercase mb-1">Sources (select any number)</div>
            <div class="d-flex flex-wrap gap-1 mb-3">
                @foreach (var src in AvailableSources())
                {
                    <button class="btn btn-sm tag-chip @(_sources.Contains(src) ? "active" : "")" @onclick="() => ToggleSource(src)">@src</button>
                }
            </div>
        </div>
    }

    @if (_result is not null && AvailableTags().Count > 0)
    {
        <div class="d-flex flex-wrap gap-1 mb-3">
            @foreach (var t in AvailableTags().Take(20))
            {
                <button class="btn btn-sm tag-chip @(_tag == t ? "active" : "")" @onclick='() => SetTag(_tag == t ? "" : t)'>@t</button>
            }
        </div>
    }
}

@if (_loading && _result is null)
{
    <p><em>Fetching the latest from across the AI world…</em></p>
}
else if (_result is null)
{
    <p>No data yet.</p>
}
else
{
    var (items, totalItems) = GetPage();
    _visibleItems = items;

    @if (_result.Errors.Count > 0)
    {
        <details class="mb-3">
            <summary class="text-warning">@_result.Errors.Count source(s) couldn't be reached</summary>
            <ul class="small text-muted mt-2">
                @foreach (var err in _result.Errors) { <li>@err</li> }
            </ul>
        </details>
    }

    <p class="text-muted small">@totalItems items</p>

    @if (_view == "Grid")
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
            @foreach (var (item, idx) in items.Select((it, i) => (it, i)))
            {
                <div class="col" id="news-item-@idx">
                    <FeedItemCard Item="item" Layout="Grid"
                                  IsNew="item.Published > _sinceVisit"
                                  WatchedKeyword='Reading.MatchWatchlist(item.Title + " " + item.Summary)'
                                  IsRead="Reading.IsRead(item.Link)"
                                  IsBookmarked="Reading.IsBookmarked(item.Link)"
                                  OnToggleRead="() => ToggleRead(item)"
                                  OnToggleBookmark="() => Toggle(item)"
                                  ShowFullTextToggle="true"
                                  Expanded="_expandedLinks.Contains(item.Link)"
                                  OnToggleExpanded="() => ToggleExpanded(item.Link)"
                                  CssClass='@(idx == _focusedIndex ? "kb-focused" : "")' />
                </div>
            }
        </div>
    }
    else
    {
        @foreach (var (item, idx) in items.Select((it, i) => (it, i)))
        {
            <div id="news-item-@idx" class="mb-2">
                <FeedItemCard Item="item" Layout="List"
                              IsNew="item.Published > _sinceVisit"
                              WatchedKeyword='Reading.MatchWatchlist(item.Title + " " + item.Summary)'
                              IsRead="Reading.IsRead(item.Link)"
                              IsBookmarked="Reading.IsBookmarked(item.Link)"
                              OnToggleRead="() => ToggleRead(item)"
                              OnToggleBookmark="() => Toggle(item)"
                              ShowFullTextToggle="true"
                              Expanded="_expandedLinks.Contains(item.Link)"
                              OnToggleExpanded="() => ToggleExpanded(item.Link)"
                              CssClass='@(idx == _focusedIndex ? "kb-focused" : "")' />
            </div>
        }
    }

    @if (totalItems == 0)
    {
        <p class="text-muted">Nothing matches the current filter/search.</p>
    }
    else
    {
        <Pager TotalItems="totalItems" @bind-CurrentPage="_page" @bind-PageSize="_pageSize" />
    }
}
</div>

<div class="news-calendar-panel">
    <h6 class="mb-2"><Icon Name="calendar" Size="16" /> Calendar</h6>
    <MonthCalendar Items="_result?.Items ?? new()" RangeStart="_dateFrom" RangeEnd="_dateTo" OnRangeChanged="OnCalendarRangeChanged" />
</div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "tag")]
    public string? TagParam { get; set; }

    [SupplyParameterFromQuery(Name = "date")]
    public string? DateParam { get; set; }

    [SupplyParameterFromQuery(Name = "dateFrom")]
    public string? DateFromParam { get; set; }

    [SupplyParameterFromQuery(Name = "dateTo")]
    public string? DateToParam { get; set; }

    [SupplyParameterFromQuery(Name = "view")]
    public string? ViewParam { get; set; }

    [SupplyParameterFromQuery(Name = "filter")]
    public string? FilterParam { get; set; }

    [SupplyParameterFromQuery(Name = "contentType")]
    public string? ContentTypeParam { get; set; }

    [SupplyParameterFromQuery(Name = "level")]
    public string? LevelParam { get; set; }

    [SupplyParameterFromQuery(Name = "source")]
    public string? SourceParam { get; set; }

    [SupplyParameterFromQuery(Name = "sort")]
    public string? SortParam { get; set; }

    private FeedResult? _result;
    private bool _loading;
    private string _filter = "All";
    private string _search = "";
    private string _contentType = "";
    private string _level = "";
    private HashSet<string> _sources = new(StringComparer.OrdinalIgnoreCase);
    private string _sort = "newest";
    private string _tag = "";
    private DateOnly? _dateFrom;
    private DateOnly? _dateTo;
    private string _view = "List";
    private bool _showFilters;
    private int _page = 1;
    private int _pageSize = 20;
    private DateTimeOffset _sinceVisit = DateTimeOffset.MinValue;
    private int _newCount;
    private List<FeedItem> _visibleItems = new();
    private readonly HashSet<string> _expandedLinks = new();
    private int _focusedIndex = -1;
    private bool _showShortcutsHelp;
    private DotNetObjectReference<News>? _dotNetRef;

    private readonly string[] _filters = { "All", "New", "Unread", "Today", "News", "Research", "Tools", "Community" };
    private readonly string[] _contentTypes = { "News", "Tutorial", "Release", "Paper", "Discussion", "Video" };
    private readonly string[] _levels = { "Beginner", "Intermediate", "Advanced" };
    private readonly string[] _sortOptions = { "newest", "oldest", "source", "title" };

    protected override void OnInitialized()
    {
        if (!string.IsNullOrWhiteSpace(TagParam))
            _tag = TagParam;
        if (DateOnly.TryParse(DateFromParam, out var dFrom) && DateOnly.TryParse(DateToParam, out var dTo))
        {
            _dateFrom = dFrom < dTo ? dFrom : dTo;
            _dateTo = dFrom < dTo ? dTo : dFrom;
        }
        else if (DateOnly.TryParse(DateParam, out var d))
        {
            _dateFrom = d;
            _dateTo = d;
        }
        if (ViewParam is "List" or "Grid")
            _view = ViewParam;
        if (!string.IsNullOrWhiteSpace(FilterParam) && _filters.Contains(FilterParam))
            _filter = FilterParam;
        if (!string.IsNullOrWhiteSpace(ContentTypeParam) && _contentTypes.Contains(ContentTypeParam))
            _contentType = ContentTypeParam;
        if (!string.IsNullOrWhiteSpace(LevelParam) && _levels.Contains(LevelParam))
            _level = LevelParam;
        if (!string.IsNullOrWhiteSpace(SourceParam))
            _sources = new HashSet<string>(SourceParam.Split(',').Select(Uri.UnescapeDataString), StringComparer.OrdinalIgnoreCase);
        if (!string.IsNullOrWhiteSpace(SortParam) && _sortOptions.Contains(SortParam))
            _sort = SortParam;

        // Peek (don't mark yet) so prerender + the interactive circuit's own OnInitializedAsync - two
        // separate component instances, both hitting this - agree on the same cutoff. Marking the visit
        // itself is deferred to OnAfterRenderAsync(firstRender), which Blazor Server guarantees runs exactly
        // once in the real circuit; doing the mutate-on-read here would let the interactive pass read back
        // the timestamp the prerender pass had just written, collapsing "New" to ~0 items every time.
        _sinceVisit = Reading.LastNewsVisit;
        // Fire-and-forget: this page must render immediately (spinner state) instead of blocking behind
        // Feeds.GetAsync() on a cold cache - with 100+ Reddit sources now in the mix sharing one
        // rate-limited host, a first-ever fetch after a restart can take 10+ minutes, and a blocking
        // OnInitializedAsync would leave the page showing nothing at all for that entire time.
        _ = Load(false);
    }

    private void SetView(string view) { _view = view; SyncUrl(); }
    private void SetFilter(string filter) { _filter = filter; SyncUrl(); }
    private void SetTag(string tag) { _tag = tag; SyncUrl(); }
    private void ClearDate() { _dateFrom = null; _dateTo = null; SyncUrl(); }

    private void SetDateRange(DateOnly start, DateOnly end) { _dateFrom = start; _dateTo = end; SyncUrl(); }
    private void OnCalendarRangeChanged((DateOnly Start, DateOnly End) range) => SetDateRange(range.Start, range.End);

    private void ToggleSource(string source)
    {
        if (!_sources.Remove(source))
            _sources.Add(source);
        SyncUrl();
    }

    private void ClearSources() { _sources.Clear(); SyncUrl(); }

    /// <summary>Reflects the current filter/view state into the URL so a refresh (or a shared link) lands back in the same place.</summary>
    private void SyncUrl()
    {
        _page = 1; // any filter/sort/view change invalidates the current page

        var query = new List<string>();
        if (_view != "List") query.Add($"view={_view}");
        if (_filter != "All") query.Add($"filter={Uri.EscapeDataString(_filter)}");
        if (!string.IsNullOrEmpty(_tag)) query.Add($"tag={Uri.EscapeDataString(_tag)}");
        if (_dateFrom is not null && _dateTo is not null)
        {
            if (_dateFrom == _dateTo) query.Add($"date={_dateFrom:yyyy-MM-dd}");
            else query.Add($"dateFrom={_dateFrom:yyyy-MM-dd}&dateTo={_dateTo:yyyy-MM-dd}");
        }
        if (!string.IsNullOrEmpty(_contentType)) query.Add($"contentType={Uri.EscapeDataString(_contentType)}");
        if (!string.IsNullOrEmpty(_level)) query.Add($"level={Uri.EscapeDataString(_level)}");
        if (_sources.Count > 0) query.Add($"source={string.Join(",", _sources.Select(Uri.EscapeDataString))}");
        if (_sort != "newest") query.Add($"sort={_sort}");
        var qs = query.Count > 0 ? "?" + string.Join("&", query) : "";
        Nav.NavigateTo($"news{qs}", replace: true);
    }

    private async Task Load(bool force)
    {
        _loading = true;
        try
        {
            _result = await Feeds.GetAsync(force);
            _newCount = _result.Items.Count(i => i.Published > _sinceVisit);
        }
        finally
        {
            _loading = false;
            StateHasChanged(); // Load() is fire-and-forget from OnInitialized(), so this is what tells the circuit to push the finished state.
        }
    }

    private int ActiveFilterCount() =>
        (string.IsNullOrEmpty(_contentType) ? 0 : 1) + (string.IsNullOrEmpty(_level) ? 0 : 1) + (_sources.Count > 0 ? 1 : 0);

    private List<string> AvailableTags() =>
        _result?.Items.SelectMany(i => i.Tags).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(t => t).ToList() ?? new();

    private List<string> AvailableSources() =>
        _result?.Items.Select(i => i.SourceName).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(s => s).ToList() ?? new();

    private List<FeedItem> Filtered()
    {
        if (_result is null) return new();
        IEnumerable<FeedItem> q = _result.Items;

        if (Reading.ExcludeFilters.Count > 0)
            q = q.Where(i => !Reading.IsExcluded(i.Title + " " + i.Summary));

        q = _filter switch
        {
            "New" => q.Where(i => i.Published > _sinceVisit),
            "Unread" => q.Where(i => !Reading.IsRead(i.Link)),
            "Today" => q.Where(i => i.Published.LocalDateTime.Date == DateTime.Today),
            "All" => q,
            _ => q.Where(i => i.Category == _filter)
        };

        if (!string.IsNullOrEmpty(_contentType))
            q = q.Where(i => i.ContentType == _contentType);

        if (!string.IsNullOrEmpty(_level))
            q = q.Where(i => i.Level == _level);

        if (_sources.Count > 0)
            q = q.Where(i => _sources.Contains(i.SourceName));

        if (!string.IsNullOrEmpty(_tag))
            q = q.Where(i => i.Tags.Contains(_tag, StringComparer.OrdinalIgnoreCase));

        if (_dateFrom is not null && _dateTo is not null)
            q = q.Where(i =>
            {
                var d = DateOnly.FromDateTime(i.Published.LocalDateTime);
                return d >= _dateFrom.Value && d <= _dateTo.Value;
            });

        if (!string.IsNullOrWhiteSpace(_search))
        {
            var s = _search.Trim();
            q = q.Where(i =>
                i.Title.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                i.Summary.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                i.SourceName.Contains(s, StringComparison.OrdinalIgnoreCase));
        }

        q = _sort switch
        {
            "oldest" => q.OrderBy(i => i.Published),
            "source" => q.OrderBy(i => i.SourceName, StringComparer.OrdinalIgnoreCase).ThenByDescending(i => i.Published),
            "title" => q.OrderBy(i => i.Title, StringComparer.OrdinalIgnoreCase),
            _ => q.OrderByDescending(i => i.Published),
        };

        return q.ToList();
    }

    private (List<FeedItem> PageItems, int Total) GetPage()
    {
        var filtered = Filtered();
        var page = filtered.Skip((_page - 1) * _pageSize).Take(_pageSize).ToList();
        return (page, filtered.Count);
    }

    private void Toggle(FeedItem item) => Reading.ToggleBookmark(item);

    private void ToggleRead(FeedItem item) => Reading.ToggleRead(item.Link);

    private void ToggleExpanded(string link)
    {
        if (!_expandedLinks.Add(link))
            _expandedLinks.Remove(link);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        Reading.TouchNewsVisit(); // now that _sinceVisit is already committed to this render, safe to mark the visit
        _dotNetRef = DotNetObjectReference.Create(this);
        try { await JS.InvokeVoidAsync("aipulseKeyboard.register", _dotNetRef); } catch { /* circuit may already be gone */ }
    }

    [JSInvokable]
    public async Task HandleKey(string key)
    {
        if (_visibleItems.Count == 0 && key is not ("?" or "Escape" or "r")) return;

        switch (key)
        {
            case "r":
                if (!_loading)
                    _ = Load(true);
                break;
            case "j":
                _focusedIndex = Math.Min(_focusedIndex + 1, _visibleItems.Count - 1);
                await JS.InvokeVoidAsync("aipulseKeyboard.scrollToFocused", _focusedIndex);
                break;
            case "k":
                _focusedIndex = _focusedIndex < 0 ? 0 : Math.Max(_focusedIndex - 1, 0);
                await JS.InvokeVoidAsync("aipulseKeyboard.scrollToFocused", _focusedIndex);
                break;
            case "o":
            case "Enter":
                if (_focusedIndex >= 0 && _focusedIndex < _visibleItems.Count)
                    await JS.InvokeVoidAsync("aipulseKeyboard.openLink", _visibleItems[_focusedIndex].Link);
                break;
            case "m":
                if (_focusedIndex >= 0 && _focusedIndex < _visibleItems.Count)
                    ToggleRead(_visibleItems[_focusedIndex]);
                break;
            case "b":
                if (_focusedIndex >= 0 && _focusedIndex < _visibleItems.Count)
                    Toggle(_visibleItems[_focusedIndex]);
                break;
            case "?":
                _showShortcutsHelp = !_showShortcutsHelp;
                break;
            case "Escape":
                _showShortcutsHelp = false;
                _focusedIndex = -1;
                break;
        }
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_dotNetRef is null) return;
        try { await JS.InvokeVoidAsync("aipulseKeyboard.unregister"); } catch { /* circuit may already be gone */ }
        _dotNetRef.Dispose();
    }
}
