@page "/login"
@layout AiPulse.Components.Layout.EmptyLayout
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@inject UserService Users
@inject OAuthSettingsService OAuthSettings
@inject IHttpContextAccessor Http
@inject NavigationManager Nav

<PageTitle>AiPulse · Sign in</PageTitle>
<HeadContent>
    <meta name="robots" content="index, follow" />
    <meta name="description" content="Sign in to AiPulse - a standalone, self-hosted dashboard to keep developers current on the AI world." />
    <link rel="canonical" href="/login" />
    <meta property="og:title" content="AiPulse - Sign in" />
    <meta property="og:description" content="A standalone, self-hosted AI news &amp; learning dashboard. No API keys required." />
</HeadContent>

<div class="login-shell-inner">
<div class="login-card">
    <div class="login-logo-wrap">
        <img src="/img/logo-v1.png" alt="AiPulse" class="app-logo login-logo" />
    </div>
    <h1 class="login-brand-mark">AiPulse</h1>
    <p class="text-muted text-center mb-4">Your AI reading &amp; learning station</p>

    <EditForm Model="Input" OnValidSubmit="SignIn" FormName="login" method="post">
        <DataAnnotationsValidator />
        @if (_error is not null)
        {
            <div class="alert alert-danger py-2">@_error</div>
        }
        @if (Error == "pending")
        {
            <div class="alert alert-warning py-2">Your account is pending admin approval.</div>
        }
        else if (Error == "disabled")
        {
            <div class="alert alert-danger py-2">This account has been disabled.</div>
        }
        <div class="mb-3">
            <label class="form-label">Username</label>
            <InputText class="form-control" @bind-Value="Input.Username" autocomplete="username" />
        </div>
        <div class="mb-3">
            <label class="form-label">Password</label>
            <InputText type="password" class="form-control" @bind-Value="Input.Password" autocomplete="current-password" />
        </div>
        <div class="form-check mb-3">
            <InputCheckbox class="form-check-input" id="remember" @bind-Value="Input.Remember" />
            <label class="form-check-label" for="remember">Keep me signed in</label>
        </div>
        <button type="submit" class="btn btn-primary w-100">Sign in</button>
    </EditForm>

    @if (_googleUsable || _githubUsable)
    {
        <div class="d-flex align-items-center gap-2 my-3">
            <hr class="flex-grow-1" /><span class="text-muted small">or</span><hr class="flex-grow-1" />
        </div>
        <div class="d-flex flex-column gap-2">
            @if (_googleUsable)
            {
                <a class="btn btn-outline-secondary w-100" href="@($"/auth/external/google?returnUrl={Uri.EscapeDataString(ReturnUrl ?? "/")}")">Sign in with Google</a>
            }
            @if (_githubUsable)
            {
                <a class="btn btn-outline-secondary w-100" href="@($"/auth/external/github?returnUrl={Uri.EscapeDataString(ReturnUrl ?? "/")}")">Sign in with GitHub</a>
            }
        </div>
    }

    <p class="text-center text-muted small mt-3 mb-0">
        <a href="/forgot-password">Forgot password?</a>
    </p>
    <p class="text-center text-muted small mt-1 mb-0">
        Don't have an account? <a href="/register">Register</a>
    </p>
</div>
<p class="login-signature">Made with <span class="text-danger">♥</span> by <a href="https://github.com/Druvo" target="_blank" rel="noopener">Druvo</a> · <a href="https://github.com/Druvo/AiPulse" target="_blank" rel="noopener">Star this repo</a></p>
</div>

@code {
    [SupplyParameterFromForm] private LoginInput Input { get; set; } = new();
    [SupplyParameterFromQuery] private string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] private string? Error { get; set; }
    private string? _error;
    private bool _googleUsable;
    private bool _githubUsable;

    protected override async Task OnInitializedAsync()
    {
        _googleUsable = await OAuthSettings.IsUsableAsync(OAuthProviders.Google);
        _githubUsable = await OAuthSettings.IsUsableAsync(OAuthProviders.GitHub);
    }

    private async Task SignIn()
    {
        var (result, user) = await Users.TryLoginAsync(Input.Username, Input.Password);

        _error = result switch
        {
            LoginResult.PendingApproval => "Your account is pending admin approval.",
            LoginResult.LockedOut => "Too many failed attempts. Try again in a few minutes, or ask an admin to unlock your account.",
            LoginResult.Success => null,
            _ => "Invalid username or password."
        };
        if (_error is not null || user is null)
            return;

        var claims = new[]
        {
            new Claim(ClaimTypes.Name, user.Username),
            new Claim(ClaimTypes.NameIdentifier, user.Id.ToString()),
            new Claim(ClaimTypes.Role, user.Role),
            new Claim("security_stamp", user.SecurityStamp)
        };
        var identity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);
        var principal = new ClaimsPrincipal(identity);

        var http = Http.HttpContext!;
        await http.SignInAsync(
            CookieAuthenticationDefaults.AuthenticationScheme,
            principal,
            new AuthenticationProperties { IsPersistent = Input.Remember });

        Nav.NavigateTo(string.IsNullOrWhiteSpace(ReturnUrl) ? "/" : ReturnUrl);
    }

    public sealed class LoginInput
    {
        public string Username { get; set; } = "";
        public string Password { get; set; } = "";
        public bool Remember { get; set; } = true;
    }
}
