@page "/reset-password"
@layout AiPulse.Components.Layout.EmptyLayout
@rendermode InteractiveServer
@inject UserService Users

<PageTitle>AiPulse · Reset password</PageTitle>
<HeadContent>
    @* Carries a single-use token in the query string - never index this. *@
    <meta name="robots" content="noindex, nofollow" />
</HeadContent>

<div class="login-shell-inner">
<div class="login-card">
    <div class="login-logo-wrap">
        <img src="/img/logo-v1.png" alt="AiPulse" class="app-logo login-logo" />
    </div>
    <h1 class="login-brand-mark">AiPulse</h1>
    <p class="text-muted text-center mb-4">Choose a new password</p>

    @if (_done)
    {
        <div class="alert alert-success">Password updated - you can sign in now.</div>
        <a class="btn btn-primary w-100" href="/login">Sign in</a>
    }
    else if (string.IsNullOrWhiteSpace(Token))
    {
        <div class="alert alert-danger py-2">That reset link is missing its token.</div>
        <a class="btn btn-primary w-100" href="/forgot-password">Request a new link</a>
    }
    else
    {
        <EditForm Model="_form" OnValidSubmit="Submit">
            @if (_error is not null)
            {
                <div class="alert alert-danger py-2">@_error</div>
            }
            <div class="mb-3">
                <label class="form-label">New password</label>
                <input type="password" class="form-control" @bind="_form.Password" autocomplete="new-password" />
            </div>
            <div class="mb-3">
                <label class="form-label">Confirm password</label>
                <input type="password" class="form-control" @bind="_form.ConfirmPassword" autocomplete="new-password" />
            </div>
            <button type="submit" class="btn btn-primary w-100">Set new password</button>
        </EditForm>
    }
</div>
<p class="login-signature">Made with <span class="text-danger">♥</span> by <a href="https://github.com/Druvo" target="_blank" rel="noopener">Druvo</a></p>
</div>

@code {
    [SupplyParameterFromQuery] private string? Token { get; set; }
    private readonly ResetForm _form = new();
    private string? _error;
    private bool _done;

    private async Task Submit()
    {
        _error = null;
        if (_form.Password != _form.ConfirmPassword)
        {
            _error = "Passwords don't match.";
            return;
        }

        var (success, error) = await Users.ResetPasswordWithTokenAsync(Token!, _form.Password);
        if (!success)
        {
            _error = error;
            return;
        }

        _done = true;
    }

    private sealed class ResetForm
    {
        public string Password { get; set; } = "";
        public string ConfirmPassword { get; set; } = "";
    }
}
