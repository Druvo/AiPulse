@* Small inline-SVG icon set — no external icon font/CDN, self-contained for a self-hosted app. *@

<svg xmlns="http://www.w3.org/2000/svg" width="@Size" height="@Size" viewBox="0 0 24 24"
     fill="@(Filled ? "currentColor" : "none")" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"
     class="ap-icon @CssClass" aria-hidden="true">
    @switch (Name)
    {
        case "home":
            <path d="M3 11.5 12 4l9 7.5" /><path d="M5.5 10v9a1 1 0 0 0 1 1H9a1 1 0 0 0 1-1v-4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v4a1 1 0 0 0 1 1h2.5a1 1 0 0 0 1-1v-9" />
            break;
        case "rss":
            <path d="M4 4c8.837 0 16 7.163 16 16" /><path d="M4 10.5c5.247 0 9.5 4.253 9.5 9.5" /><circle cx="5.5" cy="18.5" r="1.5" fill="currentColor" stroke="none" />
            break;
        case "calendar":
            <rect x="3.5" y="5" width="17" height="15.5" rx="2" /><path d="M3.5 9.5h17" /><path d="M8 3v3.5" /><path d="M16 3v3.5" />
            break;
        case "graduation-cap":
            <path d="M2.5 9 12 4.5 21.5 9 12 13.5 2.5 9Z" /><path d="M6.5 11v5c0 1.4 2.5 2.5 5.5 2.5s5.5-1.1 5.5-2.5v-5" /><path d="M21.5 9v6" />
            break;
        case "book":
            <path d="M4 5.5A2 2 0 0 1 6 3.5h13.5a.5.5 0 0 1 .5.5v14.5a.5.5 0 0 1-.5.5H6a2 2 0 0 0-2 2Z" /><path d="M4 5.5V18a2 2 0 0 0 2 2h13.5" />
            break;
        case "tool":
            <path d="M14.5 3.5a4.5 4.5 0 0 0-5.79 5.79L3.5 14.5l3 3 5.21-5.21A4.5 4.5 0 0 0 20.5 7.5l-3.25 3.25-2.5-2.5L18 5Z" />
            break;
        case "bookmark":
            <path d="M6.5 3.5h11a1 1 0 0 1 1 1V20l-6.5-4-6.5 4V4.5a1 1 0 0 1 1-1Z" />
            break;
        case "database":
            <ellipse cx="12" cy="5.5" rx="8" ry="3" /><path d="M4 5.5v13c0 1.66 3.58 3 8 3s8-1.34 8-3v-13" /><path d="M4 12c0 1.66 3.58 3 8 3s8-1.34 8-3" />
            break;
        case "settings":
            <circle cx="12" cy="12" r="3.25" /><path d="M19.4 13.5a1.7 1.7 0 0 0 .34 1.87l.06.06a2.06 2.06 0 1 1-2.92 2.92l-.06-.06a1.7 1.7 0 0 0-1.87-.34 1.7 1.7 0 0 0-1.03 1.56V19.6a2.06 2.06 0 1 1-4.12 0v-.1a1.7 1.7 0 0 0-1.11-1.56 1.7 1.7 0 0 0-1.87.34l-.06.06a2.06 2.06 0 1 1-2.92-2.92l.06-.06a1.7 1.7 0 0 0 .34-1.87 1.7 1.7 0 0 0-1.56-1.03H4.4a2.06 2.06 0 1 1 0-4.12h.1A1.7 1.7 0 0 0 6.06 6.8a1.7 1.7 0 0 0-.34-1.87l-.06-.06a2.06 2.06 0 1 1 2.92-2.92l.06.06a1.7 1.7 0 0 0 1.87.34H10.5a1.7 1.7 0 0 0 1.03-1.56V4.4a2.06 2.06 0 1 1 4.12 0v.1a1.7 1.7 0 0 0 1.03 1.56 1.7 1.7 0 0 0 1.87-.34l.06-.06a2.06 2.06 0 1 1 2.92 2.92l-.06.06a1.7 1.7 0 0 0-.34 1.87V10.5a1.7 1.7 0 0 0 1.56 1.03h.1a2.06 2.06 0 1 1 0 4.12h-.1a1.7 1.7 0 0 0-1.56 1.03Z" />
            break;
        case "bell":
            <path d="M6 9a6 6 0 1 1 12 0c0 3.5 1 5 1.5 5.5H4.5C5 14 6 12.5 6 9Z" /><path d="M9.5 17.5a2.5 2.5 0 0 0 5 0" />
            break;
        case "sun":
            <circle cx="12" cy="12" r="4" /><path d="M12 2.5v2M12 19.5v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M2.5 12h2M19.5 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4" />
            break;
        case "moon":
            <path d="M20 14.5A8.5 8.5 0 1 1 9.5 4a7 7 0 0 0 10.5 10.5Z" />
            break;
        case "logout":
            <path d="M9 3.5H5.5a1 1 0 0 0-1 1v15a1 1 0 0 0 1 1H9" /><path d="M15.5 16.5 20 12l-4.5-4.5" /><path d="M20 12H9" />
            break;
        case "zap":
            <path d="M13 3 4.5 13.5H11L10.5 21 19.5 10H13Z" stroke-linejoin="round" fill="currentColor" stroke="none" />
            break;
        case "trending-up":
            <path d="M3.5 17 10 10.5l4 4 6.5-6.5" /><path d="M15.5 8h5v5" />
            break;
        case "external-link":
            <path d="M9.5 6.5H6a1.5 1.5 0 0 0-1.5 1.5v10A1.5 1.5 0 0 0 6 19.5h10a1.5 1.5 0 0 0 1.5-1.5v-3.5" /><path d="M13.5 4.5H19.5V10.5" /><path d="M19 5 11 13" />
            break;
        case "search":
            <circle cx="10.5" cy="10.5" r="6.5" /><path d="m19.5 19.5-4.35-4.35" />
            break;
        case "star":
            <path d="M12 3.5l2.6 5.4 5.9.8-4.3 4.2 1 5.9-5.2-2.8-5.2 2.8 1-5.9-4.3-4.2 5.9-.8Z" stroke-linejoin="round" />
            break;
        case "user":
            <circle cx="12" cy="8" r="3.5" /><path d="M4.5 20a7.5 7.5 0 0 1 15 0" />
            break;
        case "list":
            <path d="M8.5 6h12M8.5 12h12M8.5 18h12" /><path d="M3.5 6h.01M3.5 12h.01M3.5 18h.01" />
            break;
        case "grid":
            <rect x="3.5" y="3.5" width="7.5" height="7.5" rx="1.5" /><rect x="13" y="3.5" width="7.5" height="7.5" rx="1.5" /><rect x="3.5" y="13" width="7.5" height="7.5" rx="1.5" /><rect x="13" y="13" width="7.5" height="7.5" rx="1.5" />
            break;
        case "refresh":
            <path d="M4.5 12a7.5 7.5 0 0 1 12.6-5.5L19.5 8.5" /><path d="M19.5 4.5v4.5H15" /><path d="M19.5 12a7.5 7.5 0 0 1-12.6 5.5L4.5 15.5" /><path d="M4.5 19.5V15H9" />
            break;
        case "sparkle":
            <path d="M12 4v3.5M12 16.5V20M4 12h3.5M16.5 12H20M6.5 6.5l1.8 1.8M15.7 15.7l1.8 1.8M17.5 6.5l-1.8 1.8M8.3 15.7l-1.8 1.8" />
            break;
        case "inbox":
            <path d="M4 12h4l1.5 3h5L16 12h4" /><path d="M5.5 5.5h13L20.5 12v6a1.5 1.5 0 0 1-1.5 1.5H5a1.5 1.5 0 0 1-1.5-1.5v-6Z" />
            break;
        case "eye":
            <path d="M2.5 12S6 5.5 12 5.5 21.5 12 21.5 12 18 18.5 12 18.5 2.5 12 2.5 12Z" /><circle cx="12" cy="12" r="2.5" />
            break;
        case "check":
            <path d="M4.5 12.5 9.5 17.5 19.5 6.5" />
            break;
        case "download":
            <path d="M12 3.5v11.5" /><path d="M7.5 11 12 15.5 16.5 11" /><path d="M4.5 17v2.5a1 1 0 0 0 1 1h13a1 1 0 0 0 1-1V17" />
            break;
        case "trash":
            <path d="M4.5 6.5h15" /><path d="M9.5 6.5V4.75a1 1 0 0 1 1-1h3a1 1 0 0 1 1 1V6.5" /><path d="M6.5 6.5 7.3 19a1.5 1.5 0 0 0 1.5 1.4h6.4a1.5 1.5 0 0 0 1.5-1.4l.8-12.5" /><path d="M10.2 10.5v6M13.8 10.5v6" />
            break;
        case "code":
            <path d="M8.5 8 4 12.5 8.5 17" /><path d="M15.5 8 20 12.5 15.5 17" /><path d="M13.5 6 10.5 19" />
            break;
        case "play":
            <path d="M6.5 4.5 19 12l-12.5 7.5Z" stroke-linejoin="round" />
            break;
        case "message":
            <path d="M4 5.5A1.5 1.5 0 0 1 5.5 4h13A1.5 1.5 0 0 1 20 5.5v9a1.5 1.5 0 0 1-1.5 1.5H9l-4.5 4v-4a1.5 1.5 0 0 1-.5-1.5Z" />
            break;
        case "stop":
            <rect x="5.5" y="5.5" width="13" height="13" rx="2" fill="currentColor" stroke="none" />
            break;
        case "copy":
            <rect x="8.5" y="8.5" width="11" height="11" rx="1.5" /><path d="M15.5 8.5V6a1.5 1.5 0 0 0-1.5-1.5H6A1.5 1.5 0 0 0 4.5 6v8A1.5 1.5 0 0 0 6 15.5h2.5" />
            break;
        case "help-circle":
            <circle cx="12" cy="12" r="9" /><path d="M9.2 9a2.8 2.8 0 1 1 4.3 2.4c-.9.6-1.5 1.1-1.5 2.3" /><circle cx="12" cy="17" r="0.15" fill="currentColor" stroke="currentColor" stroke-width="1.6" />
            break;
        case "webhook":
            <circle cx="6" cy="8" r="2.5" /><circle cx="17" cy="6" r="2.5" /><circle cx="16" cy="17" r="2.5" /><path d="M8 9.5 14 15" /><path d="M8.2 6.8 14.8 6.2" /><path d="M16.5 8.5 16.3 14.5" />
            break;
        case "activity":
            <path d="M2.5 12h4l2.5-7 4 14 2.5-7h6.5" />
            break;
        case "share":
            <path d="M12 3v12" /><path d="M8 7l4-4 4 4" /><path d="M5 12v6a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-6" />
            break;
        case "eye-off":
            <path d="M3 3l18 18" /><path d="M10.6 5.2A10.6 10.6 0 0 1 12 5c5.5 0 9 5 9.5 7-.3.9-1.2 2.6-2.7 4.1M6.7 6.7C4.6 8 3.2 10 2.5 12c.6 1.6 2.4 4.6 6.1 6.2A10.4 10.4 0 0 0 12 19c1 0 2-.15 2.9-.4" /><path d="M9.9 9.9a3 3 0 0 0 4.2 4.2" />
            break;
        case "arrow-up":
            <path d="M12 19.5V5.5" /><path d="M6 11l6-6 6 6" />
            break;
        default:
            <circle cx="12" cy="12" r="8" />
            break;
    }
</svg>

@code {
    [Parameter, EditorRequired]
    public string Name { get; set; } = "";

    [Parameter]
    public int Size { get; set; } = 18;

    [Parameter]
    public string CssClass { get; set; } = "";

    [Parameter]
    public bool Filled { get; set; }
}
