@* Top Hugging Face models + GitHub repos/developers, mirrored from the Explore page, for an at-a-glance Dashboard view. *@
@using AiPulse.Models

<div class="card h-100">
    <div class="card-body">
        <div class="d-flex align-items-center justify-content-between mb-2">
            <h6 class="section-title mb-0"><Icon Name="sparkle" Size="16" /> Trending models &amp; repos</h6>
            @if (OnRefresh.HasDelegate)
            {
                <button class="btn btn-sm btn-outline-secondary" disabled="@Loading" @onclick="OnRefresh" title="Refresh live data">
                    @if (Loading) { <span class="spinner"></span> } else { <Icon Name="refresh" Size="13" /> }
                </button>
            }
        </div>
        @if (Loading)
        {
            <p class="text-muted small mb-0"><span class="spinner"></span> Loading…</p>
        }
        else if (Models.Count == 0 && Repos.Count == 0 && Developers.Count == 0)
        {
            <p class="text-muted small mb-0">Couldn't reach Hugging Face/GitHub right now.</p>
        }
        else
        {
            @if (Models.Count > 0)
            {
                <h6 class="mb-1 x-small text-muted text-uppercase">Hugging Face</h6>
                <ul class="list-unstyled mb-2 small">
                    @foreach (var m in Models.Take(5))
                    {
                        <li class="d-flex justify-content-between align-items-center border-bottom py-1 gap-2">
                            <a href="@m.Url" target="_blank" rel="noopener" class="text-truncate">@m.Id</a>
                            <span class="text-muted text-nowrap">@m.Downloads.ToString("N0")↓</span>
                        </li>
                    }
                </ul>
            }
            @if (Repos.Count > 0)
            {
                <h6 class="mb-1 x-small text-muted text-uppercase">GitHub repos</h6>
                <ul class="list-unstyled mb-2 small">
                    @foreach (var r in Repos.Take(5))
                    {
                        <li class="d-flex justify-content-between align-items-center border-bottom py-1 gap-2">
                            <a href="@r.Url" target="_blank" rel="noopener" class="text-truncate">@r.FullName</a>
                            <span class="text-muted text-nowrap">★ @r.Stars.ToString("N0")</span>
                        </li>
                    }
                </ul>
            }
            @if (Developers.Count > 0)
            {
                <h6 class="mb-1 x-small text-muted text-uppercase">GitHub developers</h6>
                <ul class="list-unstyled mb-2 small">
                    @foreach (var d in Developers.Take(5))
                    {
                        <li class="d-flex align-items-center gap-2 border-bottom py-1">
                            <img src="@d.AvatarUrl" alt="@d.Username" class="dev-avatar-sm" />
                            <a href="@d.ProfileUrl" target="_blank" rel="noopener" class="text-truncate">@d.Username</a>
                        </li>
                    }
                </ul>
            }
            <a href="explore?tab=github" class="btn btn-sm btn-outline-primary mt-1">See more on Explore →</a>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public List<TrendingModel> Models { get; set; } = new();

    [Parameter, EditorRequired]
    public List<TrendingRepo> Repos { get; set; } = new();

    [Parameter]
    public List<TrendingDeveloper> Developers { get; set; } = new();

    [Parameter]
    public bool Loading { get; set; }

    /// <summary>Manual "Refresh" button, only shown when the caller wires this up.</summary>
    [Parameter]
    public EventCallback OnRefresh { get; set; }
}
