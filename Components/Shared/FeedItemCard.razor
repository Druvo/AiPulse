@* Shared card for rendering a single FeedItem - used by News, Bookmarks, Digest, and Home so every post
   carries the same source identity (favicon + colored-initial fallback), thumbnail, and "new" treatment
   wherever it appears, instead of each page reimplementing its own card markup. *@
@using AiPulse.Models

<div class="card h-100 @(Layout == "Grid" ? "feed-grid-card" : "feed-card-row") @(IsRead ? "read-item" : "") @(WatchedKeyword is not null ? "watched-item" : "") @CssClass">
    @if (Layout != "Compact" || !string.IsNullOrWhiteSpace(Item.ImageUrl))
    {
        <div class="feed-card-thumb feed-card-thumb-@Layout.ToLowerInvariant()">
            @if (!string.IsNullOrWhiteSpace(Item.ImageUrl))
            {
                <img src="@Item.ImageUrl" alt="" loading="lazy" onerror="this.parentElement.style.display='none'" />
            }
        </div>
    }
    <div class="card-body @(Layout == "Grid" ? "d-flex flex-column" : "") py-2">
        @if (OnToggleRead.HasDelegate || OnToggleBookmark.HasDelegate)
        {
            <div class="d-flex justify-content-end align-items-start gap-2 mb-1">
                @if (OnToggleRead.HasDelegate)
                {
                    <button class="btn btn-sm btn-link p-0 read-btn"
                            title="@(IsRead ? "Mark unread" : "Mark read")"
                            @onclick="OnToggleRead"><Icon Name="@(IsRead ? "check" : "eye")" Size="16" /></button>
                }
                @if (OnToggleBookmark.HasDelegate)
                {
                    <button class="btn btn-sm btn-link p-0 bookmark-btn @(IsBookmarked ? "saved" : "")"
                            title="@(IsBookmarked ? "Remove bookmark" : "Save to read later")"
                            @onclick="OnToggleBookmark"><Icon Name="bookmark" Size="16" Filled="@IsBookmarked" /></button>
                }
            </div>
        }
        <a href="@Item.Link" target="_blank" rel="noopener" class="h6 mb-1 d-block text-decoration-none @(IsNew ? "feed-card-title-new" : "")">
            @if (IsNew) { <span class="new-dot me-1" title="New since your last visit"></span> }
            @if (WatchedKeyword is not null) { <span class="badge bg-warning me-1" title="Watchlist: @WatchedKeyword"><Icon Name="star" Size="11" Filled="true" /></span> }
            @Item.Title
        </a>

        @if (Layout != "Compact" && !string.IsNullOrWhiteSpace(Item.Summary))
        {
            <p class="card-text small text-muted mb-2 @(Layout == "Grid" ? "line-clamp-3" : "line-clamp-2")">@Item.Summary</p>
        }

        @if (ShowFullTextToggle && !string.IsNullOrWhiteSpace(Item.FullText))
        {
            <button class="btn btn-sm btn-outline-secondary mb-2 align-self-start" @onclick="OnToggleExpanded">
                @(Expanded ? "Hide full text" : "Read full text")
            </button>
            @if (Expanded)
            {
                <p class="card-text small full-text-panel mb-2">@Item.FullText</p>
            }
        }

        @if (Layout != "Compact" && Item.Tags.Length > 0)
        {
            <div class="d-flex flex-wrap gap-1 mb-1">
                @foreach (var t in Item.Tags.Take(Layout == "Grid" ? 4 : 6))
                {
                    <span class="tag-chip small">@t</span>
                }
            </div>
        }

        <div class="x-small text-muted d-flex justify-content-between align-items-center flex-wrap gap-1 mt-auto">
            <span class="source-identity">
                <span class="source-avatar" style="--avatar-color: @AvatarColor(Item.SourceName)">
                    <span class="source-avatar-initial">@Initial(Item.SourceName)</span>
                    @{ var host = HostOf(Item.Link); }
                    @if (host is not null)
                    {
                        <img src="/favicon-proxy/@host" alt="" loading="lazy" onerror="this.style.display='none'" />
                    }
                </span>
                <span>@Item.SourceName</span>
                @if (Item.AlsoSeenOn.Length > 0)
                {
                    <span class="badge bg-secondary" title="Also covered by: @string.Join(", ", Item.AlsoSeenOn)">+@Item.AlsoSeenOn.Length more@(Item.AlsoSeenOn.Length > 1 ? " sources" : " source")</span>
                }
                <span>· @Item.Published.ToLocalTime().ToString("g")</span>
            </span>
            @if (Layout != "Compact")
            {
                <span class="d-flex align-items-center gap-1 flex-wrap">
                    <span class="badge bg-secondary text-nowrap">@Item.Category</span>
                    <span class="badge ctype-@Item.ContentType.ToLower()">@Item.ContentType</span>
                    <span class="badge level-@Item.Level.ToLower()">@Item.Level</span>
                </span>
            }
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public FeedItem Item { get; set; } = null!;
    /// <summary>"List" (image left, default), "Grid" (image on top, equal-height cards), or "Compact" (smaller footprint - no summary/tags/type badges - for Home/Digest previews).</summary>
    [Parameter] public string Layout { get; set; } = "List";
    [Parameter] public bool IsNew { get; set; }
    [Parameter] public string? WatchedKeyword { get; set; }
    [Parameter] public bool IsRead { get; set; }
    [Parameter] public bool IsBookmarked { get; set; }
    [Parameter] public EventCallback OnToggleRead { get; set; }
    [Parameter] public EventCallback OnToggleBookmark { get; set; }
    [Parameter] public bool ShowFullTextToggle { get; set; }
    [Parameter] public bool Expanded { get; set; }
    [Parameter] public EventCallback OnToggleExpanded { get; set; }
    /// <summary>Extra classes for the root card element (e.g. keyboard-nav focus ring), which are page-specific concerns the card itself doesn't know about.</summary>
    [Parameter] public string? CssClass { get; set; }

    private static string Initial(string name) =>
        string.IsNullOrWhiteSpace(name) ? "?" : char.ToUpperInvariant(name.Trim()[0]).ToString();

    /// <summary>Deterministic per-source color (hash the name to a hue) so every source has a consistent identity even before its favicon loads.</summary>
    private static string AvatarColor(string name)
    {
        var hash = 0;
        foreach (var ch in name)
            hash = (hash * 31 + ch) & 0x7fffffff;
        return $"hsl({hash % 360}, 58%, 42%)";
    }

    private static string? HostOf(string url) =>
        Uri.TryCreate(url, UriKind.Absolute, out var uri) ? uri.Host : null;
}
