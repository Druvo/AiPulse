@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 gap-4">
            <GlobalSearch />
            <NotificationBell />
            <a href="help"><Icon Name="help-circle" Size="16" /> Help</a>
            <a href="settings"><Icon Name="settings" Size="16" /> Settings</a>
            <a href="https://github.com/Druvo/AiPulse" target="_blank"><Icon Name="external-link" Size="16" /> About</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
