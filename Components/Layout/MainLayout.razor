@inherits LayoutComponentBase

@* Everything using this layout is [Authorize]-gated and would just redirect a crawler - noindex by
   default. Login/Register/ForgotPassword use EmptyLayout instead, so they're indexable without needing
   an override here (a page-level <HeadContent> here couldn't cleanly override this anyway - search
   engines combine, not replace, conflicting robots directives from multiple meta tags). *@
<HeadContent>
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content="AiPulse — a standalone, self-hosted dashboard to keep developers current on the AI world: news, jargon, the right tool for the right task, and a structured learning roadmap. Runs with zero AI and no API keys." />
    <meta property="og:title" content="AiPulse — self-hosted AI news & learning dashboard" />
    <meta property="og:description" content="Aggregates ~39 AI/dev RSS sources with a curated glossary, tools matrix, and learning roadmap. Standalone, self-hosted, no API keys required." />
</HeadContent>

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 gap-4">
            <GlobalSearch />
            <NotificationBell />
            <a href="help"><Icon Name="help-circle" Size="16" /> Help</a>
            <a href="settings"><Icon Name="settings" Size="16" /> Settings</a>
            <a href="https://github.com/Druvo/AiPulse" target="_blank"><Icon Name="external-link" Size="16" /> About</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<button type="button" id="scroll-top-btn" class="scroll-top-btn" title="Back to top" aria-label="Back to top">
    <Icon Name="arrow-up" Size="18" />
</button>

<ToastHost />

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
