    <button class="theme-toggle" type="button" onclick="toggleTheme()" title="Toggle light/dark">🌓 Theme</button>
    <AuthorizeView>
        <Authorized>
            <div class="nav-user">Signed in as <strong>@context.User.Identity?.Name</strong></div>
            <form method="post" action="/auth/logout">
                <button type="submit" class="logout-btn">Sign out</button>
            </form>
        </Authorized>
    </AuthorizeView>
</div>
