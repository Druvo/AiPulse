            <NavLink class="nav-link" href="news">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> News Feed
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="learn">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Learning Hub
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="glossary">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Glossary
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="tools">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Tools &amp; Tips
            </NavLink>
