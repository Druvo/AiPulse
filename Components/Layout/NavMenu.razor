<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">
            <Icon Name="zap" Size="20" />
            AiPulse
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-section-label px-3">Overview</div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <Icon Name="home" />
                <span>Dashboard</span>
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="news">
                <Icon Name="rss" />
                <span>News Feed</span>
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="digest">
                <Icon Name="calendar" />
                <span>Weekly Digest</span>
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="explore">
                <Icon Name="trending-up" />
                <span>Explore</span>
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="playground">
                <Icon Name="message" />
                <span>Playground</span>
            </NavLink>
        </div>

        <div class="nav-section-label px-3">Learn</div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="learn">
                <Icon Name="graduation-cap" />
                <span>Learning Hub</span>
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="glossary">
                <Icon Name="book" />
                <span>Glossary</span>
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="tools">
                <Icon Name="tool" />
                <span>Tools &amp; Tips</span>
            </NavLink>
        </div>

        <div class="nav-section-label px-3">Library</div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="bookmarks">
                <Icon Name="bookmark" />
                <span>Reading List</span>
            </NavLink>
        </div>
        <AuthorizeView Roles="Admin">
            <Authorized>
                <div class="nav-section-label px-3">Admin</div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="sources">
                        <Icon Name="database" />
                        <span>Sources</span>
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="users">
                        <Icon Name="user" />
                        <span>Users</span>
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
    </nav>
</div>

<div class="nav-footer px-3">
    <button class="theme-toggle" type="button" onclick="toggleTheme()" title="Toggle light/dark">
        <Icon Name="sun" Size="16" CssClass="icon-light" />
        <Icon Name="moon" Size="16" CssClass="icon-dark" />
        <span>Theme</span>
    </button>
    <AuthorizeView>
        <Authorized>
            <div class="nav-user">
                <Icon Name="user" Size="14" />
                <span>Signed in as <strong>@context.User.Identity?.Name</strong></span>
            </div>
            <form method="post" action="/auth/logout">
                <button type="submit" class="logout-btn">
                    <Icon Name="logout" Size="16" />
                    <span>Sign out</span>
                </button>
            </form>
        </Authorized>
    </AuthorizeView>
</div>
